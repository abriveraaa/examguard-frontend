<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="reports-root" stylesheets="@../../styles/faculty-reports.css" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.examguard.controller.faculty.FacultyReportsController">

    <VBox fillWidth="true" spacing="14">

        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="reports-header">
            <VBox minWidth="0" spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="reports-title" text="Reports" />
                <Label styleClass="reports-subtitle" text="View analytics and generate exportable academic reports." wrapText="true" />
            </VBox>

            <ComboBox fx:id="academicPeriodCombo" promptText="Academic Period" styleClass="reports-header-combo" />
            <ComboBox fx:id="courseCombo" promptText="Course" styleClass="reports-header-combo" />
            <ComboBox fx:id="sectionCombo" promptText="Section" styleClass="reports-header-combo" />

            <Button onAction="#handleRefresh" styleClass="primary-button" text="Refresh" />
        </HBox>

        <StackPane VBox.vgrow="ALWAYS">

            <VBox fx:id="reportsContent" fillWidth="true" maxWidth="Infinity" spacing="18" styleClass="reports-content">

                <HBox alignment="CENTER_LEFT" spacing="16">
                    <VBox maxWidth="Infinity" styleClass="summary-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="summary-label" text="Average Score" />
                        <Label fx:id="averageScoreLabel" styleClass="summary-value" text="0.0%" />
                    </VBox>

                    <VBox maxWidth="Infinity" styleClass="summary-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="summary-label" text="Submission Rate" />
                        <Label fx:id="submissionRateLabel" styleClass="summary-value" text="0%" />
                    </VBox>

                    <VBox maxWidth="Infinity" styleClass="summary-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="summary-label" text="Total Violations" />
                        <Label fx:id="totalViolationsLabel" styleClass="summary-value" text="0" />
                    </VBox>

                    <VBox maxWidth="Infinity" styleClass="summary-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="summary-label" text="Pending Review" />
                        <Label fx:id="pendingReviewLabel" styleClass="summary-value" text="0" />
                    </VBox>

                    <VBox maxWidth="Infinity" styleClass="summary-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="summary-label" text="Penalized" />
                        <Label fx:id="penalizedLabel" styleClass="summary-value" text="0" />
                    </VBox>
                </HBox>

                <HBox spacing="18">

                    <VBox maxWidth="Infinity" minWidth="0" spacing="18" HBox.hgrow="ALWAYS">

                        <VBox maxHeight="357.0" maxWidth="Infinity" minHeight="230" prefHeight="357.0" prefWidth="761.0" spacing="6" styleClass="chart-card">
                            <Label styleClass="section-title" text="Exam Participation and Average Score" />
                            <Label styleClass="chart-subtitle" text="Bars show total takers. Line shows average score." wrapText="true" />

                            <StackPane maxHeight="244.0" maxWidth="Infinity" minHeight="145" prefHeight="244.0" prefWidth="725.0" style="-fx-min-height: 145; -fx-pref-height: 245; -fx-max-height: 245;" styleClass="combo-chart-stack">
                                <BarChart fx:id="takersCountBarChart" animated="false" barGap="4" categoryGap="22" legendVisible="false" maxHeight="240.0" maxWidth="Infinity" minHeight="160" prefHeight="240.0" prefWidth="725.0" style="-fx-min-height: 145; -fx-pref-height: 245; -fx-max-height: 245;">
                                    <xAxis>
                                        <CategoryAxis />
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis lowerBound="0" tickUnit="10" />
                                    </yAxis>
                                </BarChart>

                                <LineChart fx:id="averageScoreLineChart" alternativeRowFillVisible="false" animated="false" horizontalGridLinesVisible="false" legendVisible="false" maxHeight="223.0" maxWidth="Infinity" minHeight="160" prefHeight="223.0" prefWidth="725.0" style="-fx-min-height: 145; -fx-pref-height: 165; -fx-max-height: 180;" styleClass="average-score-line-chart" verticalGridLinesVisible="false">
                                    <xAxis>
                                        <CategoryAxis opacity="0" />
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis lowerBound="0" opacity="0" tickUnit="10" upperBound="100" />
                                    </yAxis>
                                </LineChart>
                            </StackPane>

                            <HBox alignment="CENTER" spacing="12" styleClass="manual-chart-legend">
                                <HBox alignment="CENTER" spacing="6">
                                    <Region styleClass="legend-bar" />
                                    <Label text="Total Takers" />
                                </HBox>
                                <HBox alignment="CENTER" spacing="6">
                                    <Region styleClass="legend-line" />
                                    <Label text="Average Score" />
                                </HBox>
                            </HBox>
                        </VBox>

                        <VBox maxWidth="Infinity" minHeight="350" prefHeight="400.0" prefWidth="761.0" spacing="10" styleClass="chart-card">

                            <TabPane maxWidth="Infinity" minHeight="320" styleClass="report-tab-pane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

                                <tabs>
                                    <Tab text="Violation Breakdown">
                                        <VBox fillWidth="true" maxWidth="Infinity" minHeight="280" spacing="10">
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <Label styleClass="chart-subtitle" text="Flagged incidents grouped by violation type." wrapText="true" />
                                            </HBox>

                                            <StackedBarChart fx:id="violationStackedChart" animated="false" legendVisible="true" maxHeight="Infinity" maxWidth="Infinity" minHeight="230" prefHeight="244.0" prefWidth="723.0" VBox.vgrow="ALWAYS">

                                                <xAxis>
                                                    <CategoryAxis />
                                                </xAxis>

                                                <yAxis>
                                                    <NumberAxis lowerBound="0" tickUnit="20" upperBound="100" />
                                                </yAxis>

                                            </StackedBarChart>
                                        </VBox>
                                    </Tab>

                                    <Tab text="Submission Breakdown">
                                        <VBox fillWidth="true" maxWidth="Infinity" minHeight="280" spacing="10">
                                            <Label styleClass="chart-subtitle" text="Per-exam submitted, in-progress, and did-not-take counts." wrapText="true" />

                                            <StackedBarChart fx:id="submissionStackedChart" animated="false" legendVisible="true" maxHeight="Infinity" maxWidth="Infinity" minHeight="230" VBox.vgrow="ALWAYS">

                                                <xAxis>
                                                    <CategoryAxis />
                                                </xAxis>

                                                <yAxis>
                                                    <NumberAxis lowerBound="0" tickUnit="20" upperBound="100" />
                                                </yAxis>

                                            </StackedBarChart>
                                        </VBox>
                                    </Tab>
                                </tabs>
                            </TabPane>
                        </VBox>
                    </VBox>

                    <VBox alignment="TOP_CENTER" maxWidth="Infinity" minWidth="300" spacing="18" styleClass="reports-side-panel" HBox.hgrow="SOMETIMES">

                        <VBox alignment="TOP_CENTER" maxWidth="Infinity" prefHeight="356.0" prefWidth="390.0" spacing="10" styleClass="chart-card">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label styleClass="section-title" text="Submission Status" />

                                <Region HBox.hgrow="ALWAYS" />

                                <ComboBox fx:id="submissionExamCombo" promptText="Select Exam" styleClass="chart-card-combo" />
                            </HBox>

                            <PieChart fx:id="submissionPieChart" legendVisible="false" maxHeight="Infinity" maxWidth="Infinity" minHeight="240" />
                        </VBox>

                        <VBox maxWidth="Infinity" prefHeight="402.0" prefWidth="390.0" spacing="12" styleClass="available-card">
                            <Label styleClass="section-title" text="Available Reports" />

                            <VBox fillWidth="true" spacing="10">
                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="report-row">
                                    <Label styleClass="report-title" text="Student Roster" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#handleExportClassRoster" styleClass="report-export-button" text="Export" />
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="report-row">
                                    <Label styleClass="report-title" text="Class Record" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#handleExportGradebook" styleClass="report-export-button" text="Export" />
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="report-row">
                                    <Label styleClass="report-title" text="Exam Portfolio" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#handleExportExamPortfolio" styleClass="report-export-button" text="Export" />
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="report-row">
                                    <Label styleClass="report-title" text="Exam Results Summary" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#handleExportExamResultsSummary" styleClass="report-export-button" text="Export" />
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>

            <StackPane fx:id="loadingOverlay" managed="false" styleClass="loading-overlay" visible="false">

                <VBox alignment="CENTER" spacing="12" styleClass="loading-box">
                    <ProgressIndicator prefHeight="42" prefWidth="42" />
                    <Label styleClass="loading-label" text="Loading reports..." />
                </VBox>
            </StackPane>

        </StackPane>
    </VBox>
</ScrollPane>

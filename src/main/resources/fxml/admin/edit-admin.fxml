<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox minHeight="500.0" minWidth="450.0" spacing="16" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 18;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.examguard.controller.admin.EditAdminController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <VBox spacing="4">
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #302C29;"
               text="Edit Admin Profile" />
        <Label style="-fx-font-size: 12px; -fx-text-fill: #7b7470;"
               text="Edit profile details of this account." wrapText="true" />
    </VBox>
    <Pane prefHeight="10.0" />

    <GridPane hgap="12" prefWidth="345.0" vgap="12">
        <columnConstraints>
            <ColumnConstraints percentWidth="35" />
            <ColumnConstraints percentWidth="65" />
        </columnConstraints>

        <Label text="Employee ID" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="employeeIdField" minHeight="40.0" promptText="e.g. 2026-ADMIN-002" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="First Name" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="firstNameField" minHeight="40.0" promptText="Enter first name" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Last Name" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="lastNameField" minHeight="40.0" promptText="Enter last name" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="Email" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="emailField" minHeight="40.0" promptText="Enter email" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label text="Birth Date" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <DatePicker fx:id="birthDatePicker" minHeight="40.0" prefHeight="40.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>
    </GridPane>

    <Label fx:id="errorLabel" alignment="CENTER" style="-fx-text-fill: #b42318; -fx-font-size: 12px;" text="" textAlignment="CENTER" wrapText="true" />

    <HBox alignment="CENTER_LEFT" spacing="10">

        <Button fx:id="deactivateButton"
                onAction="#handleDeactivate"
                text="Deactivate"
                style="-fx-background-color: #b91c1c;
                   -fx-text-fill: white;
                   -fx-background-radius: 10;
                   -fx-padding: 8 18;
                   -fx-cursor: hand;" />

        <Button fx:id="reactivateButton"
                onAction="#handleReactivate"
                text="Reactivate"
                visible="false"
                managed="false"
                style="-fx-background-color: #15803d;
                   -fx-text-fill: white;
                   -fx-background-radius: 10;
                   -fx-padding: 8 18;
                   -fx-cursor: hand;" />

        <Region HBox.hgrow="ALWAYS" />

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Cancel"
                    onAction="#handleCancel"
                    style="-fx-background-color: #e5e7eb;
                       -fx-text-fill: #302C29;
                       -fx-background-radius: 10;
                       -fx-padding: 8 18;
                       -fx-cursor: hand;" />

            <Button fx:id="saveButton"
                    text="Update"
                    onAction="#handleUpdate"
                    style="-fx-background-color: #C9A227;
                       -fx-text-fill: white;
                       -fx-background-radius: 10;
                       -fx-padding: 8 18;
                       -fx-cursor: hand;" />
        </HBox>

    </HBox>

</VBox>

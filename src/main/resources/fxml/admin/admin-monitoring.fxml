<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.examguard.controller.admin.AdminMonitoringController"
            styleClass="monitoring-page"
            stylesheets="@../../styles/admin-monitoring.css">

    <top>
        <VBox spacing="14">
            <padding>
                <Insets top="0" right="0" bottom="16" left="0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Monitoring Overview" styleClass="page-title"/>
                    <Label text="Track violations, system logs, session activity, and concurrent users."
                           styleClass="page-subtitle"/>
                </VBox>

                <ComboBox fx:id="rangeComboBox"
                          promptText="Range"
                          prefWidth="170"/>

                <DatePicker fx:id="customStartDatePicker"
                            promptText="Start Date"
                            prefWidth="150"
                            visible="false"
                            managed="false"/>

                <DatePicker fx:id="customEndDatePicker"
                            promptText="End Date"
                            prefWidth="150"
                            visible="false"
                            managed="false"/>

                <Button text="Refresh"
                        onAction="#handleRefresh"
                        styleClass="primary-button"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="18">

            <VBox spacing="10"
                  prefWidth="210"
                  minWidth="210"
                  maxWidth="210"
                  styleClass="monitoring-sidebar">

                <Button fx:id="allLogsTabButton"
                        text="All Logs"
                        prefWidth="180"
                        minWidth="180"
                        maxWidth="180"
                        onAction="#showAllLogsPane"
                        styleClass="side-tab"/>

                <Button fx:id="violationLogsTabButton"
                        text="Violation Logs"
                        prefWidth="180"
                        minWidth="180"
                        maxWidth="180"
                        onAction="#showViolationLogsPane"
                        styleClass="side-tab"/>

                <Button fx:id="systemLogsTabButton"
                        text="System Logs"
                        prefWidth="180"
                        minWidth="180"
                        maxWidth="180"
                        onAction="#showSystemLogsPane"
                        styleClass="side-tab"/>

                <Button fx:id="sessionsTabButton"
                        text="Sessions"
                        prefWidth="180"
                        minWidth="180"
                        maxWidth="180"
                        onAction="#showSessionsPane"
                        styleClass="side-tab"/>

                <Button fx:id="accessLogsTabButton"
                        text="Access Logs"
                        onAction="#showAccessLogsPane"
                        prefWidth="180"
                        minWidth="180"
                        maxWidth="180"
                        styleClass="side-tab" />

                <Button fx:id="accountLogsTabButton"
                        text="Account Logs"
                        onAction="#showAccountLogsPane"
                        prefWidth="180"
                        minWidth="180"
                        maxWidth="180"
                        styleClass="side-tab" />

                <Button fx:id="registrarLogsTabButton"
                        text="Registrar Sync"
                        onAction="#showRegistrarLogsPane"
                        prefWidth="180"
                        minWidth="180"
                        maxWidth="180"
                        styleClass="side-tab" />

                <Button fx:id="cameraSessionsTabButton"
                        text="Camera Sessions"
                        onAction="#showCameraSessionsPane"
                        prefWidth="180"
                        minWidth="180"
                        maxWidth="180"
                        styleClass="side-tab" />
            </VBox>

            <StackPane fx:id="contentStack" HBox.hgrow="ALWAYS">

                <!-- ALL LOGS -->
                <VBox fx:id="allLogsPane"
                      visible="false"
                      managed="false"
                      spacing="12"
                      styleClass="monitoring-content">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <TextField fx:id="allLogsSearchField"
                                   promptText="Search all logs..."
                                   HBox.hgrow="ALWAYS"/>

                        <MenuButton text="Export" styleClass="secondary-button">
                            <items>
                                <MenuItem text="Export as PDF" onAction="#handleExportAllLogsPdf"/>
                                <MenuItem text="Export as Excel" onAction="#handleExportAllLogsExcel"/>
                            </items>
                        </MenuButton>
                    </HBox>

                    <TableView fx:id="allLogsTable" VBox.vgrow="ALWAYS" >
                        <columns>
                            <TableColumn fx:id="allLogTimeColumn" text="Time" prefWidth="170"/>
                            <TableColumn fx:id="allLogTypeColumn" text="Type" prefWidth="120"/>
                            <TableColumn fx:id="allLogActorColumn" text="Actor" prefWidth="170"/>
                            <TableColumn fx:id="allLogActorRoleColumn" text="Actor Role" prefWidth="120" />
                            <TableColumn fx:id="allLogTargetUserColumn" text="Target User" prefWidth="150" />
                            <TableColumn fx:id="allLogTargetRoleColumn" text="Target Role" prefWidth="120" />
                            <TableColumn fx:id="allLogModuleColumn" text="Module" prefWidth="150"/>
                            <TableColumn fx:id="allLogActionColumn" text="Action" prefWidth="150"/>
                            <TableColumn fx:id="allLogStatusColumn" text="Status" prefWidth="120"/>
                            <TableColumn fx:id="allLogMessageColumn" text="Message" prefWidth="350"/>
                            <TableColumn fx:id="allLogDurationColumn" text="Duration" prefWidth="120" />
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="allLogsPageLabel" text="Page 1 of 1" styleClass="pagination-label" />
                        <Button fx:id="allLogsPrevButton" text="Previous" onAction="#handleAllLogsPrevious" styleClass="secondary-button" />
                        <Button fx:id="allLogsNextButton" text="Next" onAction="#handleAllLogsNext" styleClass="primary-button" />
                    </HBox>
                </VBox>

                <!-- VIOLATION LOGS -->
                <VBox fx:id="violationLogsPane"
                      visible="false"
                      managed="false"
                      spacing="12"
                      styleClass="monitoring-content">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <TextField fx:id="violationSearchField"
                                   promptText="Search violations..."
                                   HBox.hgrow="ALWAYS"/>

                        <ComboBox fx:id="violationTypeFilterComboBox"
                                  promptText="Violation Type"
                                  prefWidth="170"/>

                        <ComboBox fx:id="violationSeverityFilterComboBox"
                                  promptText="Severity"
                                  prefWidth="140"/>

                        <ComboBox fx:id="violationStatusFilterComboBox"
                                  promptText="Review Status"
                                  prefWidth="160"/>

                        <MenuButton text="Export" styleClass="secondary-button">
                            <items>
                                <MenuItem text="Export as PDF" onAction="#handleExportViolationLogsPdf"/>
                                <MenuItem text="Export as Excel" onAction="#handleExportViolationLogsExcel"/>
                            </items>
                        </MenuButton>
                    </HBox>

                    <TableView fx:id="violationLogsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="violationTimeColumn" text="Time" prefWidth="170"/>
                            <TableColumn fx:id="violationStudentColumn" text="Student" prefWidth="180"/>
                            <TableColumn fx:id="violationCourseColumn" text="Course" prefWidth="120" />
                            <TableColumn fx:id="violationExamTitleColumn" text="Exam" prefWidth="220" />
                            <TableColumn fx:id="violationQuestionColumn" text="Question #" prefWidth="100" />
                            <TableColumn fx:id="violationTypeColumn" text="Violation" prefWidth="160"/>
                            <TableColumn fx:id="violationSeverityColumn" text="Severity" prefWidth="120"/>
                            <TableColumn fx:id="violationStatusColumn" text="Review Status" prefWidth="150"/>
                            <TableColumn fx:id="violationMessageColumn" text="Message" prefWidth="360"/>
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="violationLogsPageLabel" text="Page 1 of 1"  styleClass="pagination-label"  />
                        <Button fx:id="violationLogsPrevButton" text="Previous" onAction="#handleViolationLogsPrevious" styleClass="secondary-button" />
                        <Button fx:id="violationLogsNextButton" text="Next" onAction="#handleViolationLogsNext" styleClass="primary-button" />
                    </HBox>
                </VBox>

                <!-- SYSTEM LOGS -->
                <VBox fx:id="systemLogsPane"
                      visible="false"
                      managed="false"
                      spacing="12"
                      styleClass="monitoring-content">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <TextField fx:id="systemSearchField"
                                   promptText="Search system logs..."
                                   HBox.hgrow="ALWAYS"/>

                        <ComboBox fx:id="systemModuleFilterComboBox"
                                  promptText="Module"
                                  prefWidth="150"/>

                        <ComboBox fx:id="systemStatusFilterComboBox"
                                  promptText="Status"
                                  prefWidth="130"/>

                        <ComboBox fx:id="systemRoleFilterComboBox"
                                  promptText="Actor Role"
                                  prefWidth="140"/>

                        <MenuButton text="Export" styleClass="secondary-button">
                            <items>
                                <MenuItem text="Export as PDF" onAction="#handleExportSystemLogsPdf"/>
                                <MenuItem text="Export as Excel" onAction="#handleExportSystemLogsExcel"/>
                            </items>
                        </MenuButton>
                    </HBox>

                    <TableView fx:id="systemLogsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="systemTimeColumn" text="Time" prefWidth="170"/>
                            <TableColumn fx:id="systemActorColumn" text="Actor" prefWidth="180"/>
                            <TableColumn fx:id="systemRoleColumn" text="Role" prefWidth="110"/>
                            <TableColumn fx:id="systemTargetUserColumn" text="Target User" prefWidth="150" />
                            <TableColumn fx:id="systemTargetRoleColumn" text="Target Role" prefWidth="120" />
                            <TableColumn fx:id="systemModuleColumn" text="Module" prefWidth="150"/>
                            <TableColumn fx:id="systemActionColumn" text="Action" prefWidth="150"/>
                            <TableColumn fx:id="systemStatusColumn" text="Status" prefWidth="120"/>
                            <TableColumn fx:id="systemMessageColumn" text="Message" prefWidth="420"/>
                            <TableColumn fx:id="systemDurationColumn" text="Duration" prefWidth="120" />
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="systemLogsPageLabel" text="Page 1 of 1"  styleClass="pagination-label"  />
                        <Button fx:id="systemLogsPrevButton" text="Previous" onAction="#handleSystemLogsPrevious" styleClass="secondary-button" />
                        <Button fx:id="systemLogsNextButton" text="Next" onAction="#handleSystemLogsNext" styleClass="primary-button" />
                    </HBox>
                </VBox>

                <!-- SESSIONS -->
                <VBox fx:id="sessionsPane"
                      visible="false"
                      managed="false"
                      spacing="12"
                      styleClass="monitoring-content">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <TextField fx:id="sessionSearchField"
                                   promptText="Search sessions..."
                                   HBox.hgrow="ALWAYS"/>

                        <ComboBox fx:id="sessionStatusFilterComboBox"
                                  promptText="Status"
                                  prefWidth="140"/>

                        <ComboBox fx:id="sessionRoleFilterComboBox"
                                  promptText="Role"
                                  prefWidth="130"/>

                        <MenuButton text="Export" styleClass="secondary-button">
                            <items>
                                <MenuItem text="Export as PDF" onAction="#handleExportSessionLogsPdf"/>
                                <MenuItem text="Export as Excel" onAction="#handleExportSessionLogsExcel"/>
                            </items>
                        </MenuButton>
                    </HBox>

                    <TableView fx:id="sessionLogsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="sessionStartedColumn" text="Started" prefWidth="170"/>
                            <TableColumn fx:id="sessionUserColumn" text="User" prefWidth="180"/>
                            <TableColumn fx:id="sessionRoleColumn" text="Role" prefWidth="110"/>
                            <TableColumn fx:id="sessionDeviceColumn" text="Device" prefWidth="180"/>
                            <TableColumn fx:id="sessionIpColumn" text="IP Address" prefWidth="150"/>
                            <TableColumn fx:id="sessionStatusColumn" text="Status" prefWidth="120"/>
                            <TableColumn fx:id="sessionLastSeenColumn" text="Last Seen" prefWidth="170"/>
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="sessionLogsPageLabel" text="Page 1 of 1"  styleClass="pagination-label"  />
                        <Button fx:id="sessionLogsPrevButton" text="Previous" onAction="#handleSessionLogsPrevious" styleClass="secondary-button" />
                        <Button fx:id="sessionLogsNextButton" text="Next" onAction="#handleSessionLogsNext" styleClass="primary-button" />
                    </HBox>
                </VBox>

                <!-- ACCESS LOGS -->
                <VBox fx:id="accessLogsPane" visible="false" managed="false" spacing="14" styleClass="tab-content">

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="accessSearchField"
                                   promptText="Search access logs..."
                                   HBox.hgrow="ALWAYS"/>

                        <ComboBox fx:id="accessEventTypeFilterComboBox"
                                  promptText="Event Type"
                                  prefWidth="150"/>

                        <ComboBox fx:id="accessStatusFilterComboBox"
                                  promptText="Status"
                                  prefWidth="130"/>

                        <ComboBox fx:id="accessRoleFilterComboBox"
                                  promptText="Role"
                                  prefWidth="130"/>

                        <MenuButton text="Export" styleClass="secondary-button">
                            <items>
                                <MenuItem text="Export as PDF" onAction="#handleExportAccessLogsPdf"/>
                                <MenuItem text="Export as Excel" onAction="#handleExportAccessLogsExcel"/>
                            </items>
                        </MenuButton>
                    </HBox>

                    <TableView fx:id="accessLogsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="accessTimeColumn" text="Time" prefWidth="170" />
                            <TableColumn fx:id="accessActorColumn" text="User" prefWidth="150" />
                            <TableColumn fx:id="accessActionColumn" text="Event" prefWidth="140" />
                            <TableColumn fx:id="accessStatusColumn" text="Status" prefWidth="120" />
                            <TableColumn fx:id="accessMessageColumn" text="Message" prefWidth="420" />
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="accessLogsPageLabel" text="Page 1 of 1" styleClass="pagination-label" />
                        <Button fx:id="accessLogsPrevButton" text="Previous" onAction="#handleAccessLogsPrevious" styleClass="secondary-button" />
                        <Button fx:id="accessLogsNextButton" text="Next" onAction="#handleAccessLogsNext" styleClass="primary-button" />
                    </HBox>

                </VBox>

                <!-- ACCOUNT LOGS -->
                <VBox fx:id="accountLogsPane" visible="false" managed="false" spacing="14" styleClass="tab-content">

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="accountSearchField"
                                   promptText="Search account logs..."
                                   HBox.hgrow="ALWAYS"/>

                        <ComboBox fx:id="accountActionFilterComboBox"
                                  promptText="Action"
                                  prefWidth="150"/>

                        <ComboBox fx:id="accountStatusFilterComboBox"
                                  promptText="Status"
                                  prefWidth="130"/>

                        <ComboBox fx:id="accountRoleFilterComboBox"
                                  promptText="Role"
                                  prefWidth="130"/>

                        <MenuButton text="Export" styleClass="secondary-button">
                            <items>
                                <MenuItem text="Export as PDF" onAction="#handleExportAccountLogsPdf"/>
                                <MenuItem text="Export as Excel" onAction="#handleExportAccountLogsExcel"/>
                            </items>
                        </MenuButton>
                    </HBox>

                    <TableView fx:id="accountLogsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="accountTimeColumn" text="Time" prefWidth="170" />
                            <TableColumn fx:id="accountActorColumn" text="Performed By" prefWidth="150" />
                            <TableColumn fx:id="accountActionColumn" text="Action" prefWidth="140" />
                            <TableColumn fx:id="accountStatusColumn" text="New Status" prefWidth="120" />
                            <TableColumn fx:id="accountMessageColumn" text="Reason" prefWidth="420" />
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="accountLogsPageLabel" text="Page 1 of 1" styleClass="pagination-label" />
                        <Button fx:id="accountLogsPrevButton" text="Previous" onAction="#handleAccountLogsPrevious" styleClass="secondary-button" />
                        <Button fx:id="accountLogsNextButton" text="Next" onAction="#handleAccountLogsNext" styleClass="primary-button" />
                    </HBox>

                </VBox>

                <!-- REGISTRAR SYNC -->
                <VBox fx:id="registrarLogsPane" visible="false" managed="false" spacing="14" styleClass="tab-content">

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="registrarSearchField"
                                   promptText="Search registrar sync logs..."
                                   HBox.hgrow="ALWAYS"/>

                        <ComboBox fx:id="registrarSyncTypeFilterComboBox"
                                  promptText="Sync Type"
                                  prefWidth="150"/>

                        <ComboBox fx:id="registrarStatusFilterComboBox"
                                  promptText="Status"
                                  prefWidth="130"/>

                        <MenuButton text="Export" styleClass="secondary-button">
                            <items>
                                <MenuItem text="Export as PDF" onAction="#handleExportRegistrarLogsPdf"/>
                                <MenuItem text="Export as Excel" onAction="#handleExportRegistrarLogsExcel"/>
                            </items>
                        </MenuButton>
                    </HBox>

                    <TableView fx:id="registrarLogsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="registrarTimeColumn" text="Time" prefWidth="170" />
                            <TableColumn fx:id="registrarActorColumn" text="Performed By" prefWidth="150" />
                            <TableColumn fx:id="registrarActionColumn" text="Sync Type" prefWidth="140" />
                            <TableColumn fx:id="registrarStatusColumn" text="Status" prefWidth="120" />
                            <TableColumn fx:id="registrarMessageColumn" text="Message" prefWidth="420" />
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="registrarLogsPageLabel" text="Page 1 of 1" styleClass="pagination-label" />
                        <Button fx:id="registrarLogsPrevButton" text="Previous" onAction="#handleRegistrarLogsPrevious" styleClass="secondary-button" />
                        <Button fx:id="registrarLogsNextButton" text="Next" onAction="#handleRegistrarLogsNext" styleClass="primary-button" />
                    </HBox>

                </VBox>

                <!-- CAMERA SESSIONS -->
                <VBox fx:id="cameraSessionsPane"
                      visible="false"
                      managed="false"
                      spacing="14"
                      styleClass="tab-content">

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="cameraSearchField"
                                   promptText="Search camera sessions..."
                                   HBox.hgrow="ALWAYS"/>

                        <ComboBox fx:id="cameraStatusFilterComboBox"
                                  promptText="Status"
                                  prefWidth="140"/>

                        <ComboBox fx:id="cameraDeviceTypeFilterComboBox"
                                  promptText="Device Type"
                                  prefWidth="150"/>

                        <ComboBox fx:id="cameraStreamRoleFilterComboBox"
                                  promptText="Stream Role"
                                  prefWidth="170"/>

                        <MenuButton text="Export" styleClass="secondary-button">
                            <items>
                                <MenuItem text="Export as PDF" onAction="#handleExportCameraSessionsPdf"/>
                                <MenuItem text="Export as Excel" onAction="#handleExportCameraSessionsExcel"/>
                            </items>
                        </MenuButton>
                    </HBox>

                    <TableView fx:id="cameraSessionsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="cameraTimeColumn" text="Started" prefWidth="170"/>
                            <TableColumn fx:id="cameraStudentColumn" text="Student" prefWidth="170"/>
                            <TableColumn fx:id="cameraExamColumn" text="Exam ID" prefWidth="100"/>
                            <TableColumn fx:id="cameraAttemptColumn" text="Attempt ID" prefWidth="100"/>
                            <TableColumn fx:id="cameraDeviceColumn" text="Device" prefWidth="180"/>
                            <TableColumn fx:id="cameraStatusColumn" text="Status" prefWidth="130"/>
                            <TableColumn fx:id="cameraMessageColumn" text="Details" prefWidth="420"/>
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="cameraSessionsPageLabel"
                               text="Page 1 of 1"
                               styleClass="pagination-label"/>

                        <Button fx:id="cameraSessionsPrevButton"
                                text="Previous"
                                onAction="#handleCameraSessionsPrevious"
                                styleClass="secondary-button"/>

                        <Button fx:id="cameraSessionsNextButton"
                                text="Next"
                                onAction="#handleCameraSessionsNext"
                                styleClass="primary-button"/>
                    </HBox>
                </VBox>

            </StackPane>
        </HBox>
    </center>

</BorderPane>
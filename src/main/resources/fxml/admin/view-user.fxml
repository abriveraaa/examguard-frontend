<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="page-root"
            stylesheets="@/styles/admin-page.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.examguard.controller.admin.UserViewDialogController">

    <!-- ================= LEFT: PROFILE CARD ================= -->
    <left>
        <VBox alignment="TOP_CENTER"
              maxWidth="350"
              minWidth="300"
              prefWidth="300"
              spacing="12"
              styleClass="card profile-card">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <ImageView fx:id="photoView"
                       fitHeight="250"
                       fitWidth="250"
                       preserveRatio="true"
                       smooth="true"
                       styleClass="profile-photo" />

            <Label fx:id="roleLabel"
                   text="ROLE"
                   styleClass="profile-role" />
        </VBox>
    </left>

    <!-- ================= CENTER: DETAILS ================= -->
    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;">

            <content>
                <VBox alignment="TOP_LEFT"
                      spacing="14"
                      styleClass="page-content">

                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <!-- ACCOUNT SECTION -->
                    <VBox spacing="10" styleClass="card section-card">

                        <Label text="Account Information"
                               styleClass="section-title" />

                        <GridPane fx:id="accountBox"
                                  hgap="10"
                                  vgap="10">

                            <columnConstraints>
                                <ColumnConstraints minWidth="140" maxWidth="140" hgrow="NEVER" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>

                        </GridPane>
                    </VBox>

                    <!-- ACADEMIC WRAPPER -->
                    <VBox fx:id="academicSection"
                          spacing="10"
                          styleClass="card section-card">

                        <Label text="Academic Information"
                               styleClass="section-title" />

                        <GridPane fx:id="academicBox"
                                  hgap="10"
                                  vgap="10">

                            <columnConstraints>
                                <ColumnConstraints minWidth="140" maxWidth="140" hgrow="NEVER" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>

                        </GridPane>
                    </VBox>

                    <!-- ACCOUNT SECTION -->
                    <VBox spacing="10" styleClass="card section-card">

                        <Label text="Account Status"
                               styleClass="section-title" />

                        <GridPane fx:id="accountStatus"
                                  hgap="10"
                                  vgap="10">

                            <columnConstraints>
                                <ColumnConstraints minWidth="140" maxWidth="140" hgrow="NEVER" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>

                        </GridPane>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- ================= BOTTOM: ACTION BAR ================= -->
    <bottom>
        <HBox alignment="CENTER_RIGHT"
              spacing="10"
              styleClass="page-footer">

            <padding>
                <Insets top="10" right="20" bottom="20" left="20"/>
            </padding>

            <children>
                <Button fx:id="reactivateButton"
                        text="Reactivate Access"
                        visible="false"
                        managed="false"
                        onAction="#handleReactivate"
                        style="-fx-background-color: #800000;
                           -fx-text-fill: white;
                           -fx-background-radius: 10;
                           -fx-padding: 8 18;
                           -fx-cursor: hand;" />

                <Button fx:id="closeButton"
                        text="Close"
                        onAction="#handleClose"
                        style="-fx-background-color: #302C29;
                           -fx-text-fill: white;
                           -fx-background-radius: 10;
                           -fx-padding: 8 18;
                           -fx-cursor: hand;" />
            </children>
        </HBox>
    </bottom>

</BorderPane>
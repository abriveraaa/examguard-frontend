<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="24" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.examguard.controller.profile.ChangePasswordController">

    <children>

        <VBox maxWidth="850" spacing="18" style="-fx-background-color: white;                      -fx-background-radius: 16;                      -fx-padding: 28;                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4);">

            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #302C29;" text="Change Password" />

            <Label fx:id="mustChangeLabel" managed="false" style="-fx-text-fill: #b91c1c; -fx-font-weight: bold; -fx-font-size: 13px;" text="You must change your temporary password before continuing." visible="false" wrapText="true" />

            <VBox spacing="14">
                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Current Password" />
                <PasswordField fx:id="currentPasswordField" prefHeight="42" style="-fx-background-radius: 8; -fx-border-radius: 8;" />
            </VBox>

            <VBox spacing="6">

                <Label fx:id="passwordRulesLabel" style="-fx-text-fill: #666666; -fx-font-size: 12px;" wrapText="true" />

                <Label fx:id="errorLabel" managed="false" style="-fx-text-fill: #b91c1c; -fx-font-size: 12px; -fx-font-weight: bold;" visible="false" wrapText="true" />

            </VBox>

            <VBox spacing="10.0">

                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="New Password" />

                <!-- NEW PASSWORD WITH TOGGLE -->
                <StackPane maxWidth="1.7976931348623157E308">
                    <children>
                        <PasswordField fx:id="newPasswordField" prefHeight="42" style="-fx-background-radius: 8; -fx-border-radius: 8;" />
                        <TextField fx:id="newPasswordVisibleField" managed="false" prefHeight="42" style="-fx-background-radius: 8; -fx-border-radius: 8;" visible="false" />

                        <Button fx:id="toggleNewPasswordButton" focusTraversable="false" onAction="#handleToggleNewPassword" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 14px;" text="👁" StackPane.alignment="CENTER_RIGHT">
                            <StackPane.margin>
                                <Insets right="10.0" />
                            </StackPane.margin>
                        </Button>
                    </children>
                </StackPane>

                <!-- STRENGTH BAR -->
                <VBox spacing="6">
                    <ProgressBar fx:id="passwordStrengthBar" prefWidth="400" progress="0.0" style="-fx-accent: #d1d5db;" />

                    <Label fx:id="passwordStrengthLabel" style="-fx-font-size: 12px; -fx-text-fill: #666666;" text="Password strength" />

                    <VBox fx:id="passwordRulesBox" spacing="4">
                        <Label fx:id="ruleLengthLabel" style="-fx-font-size: 12px;" text="• At least 8 characters" />
                        <Label fx:id="ruleUpperLabel" style="-fx-font-size: 12px;" text="• One uppercase letter" />
                        <Label fx:id="ruleLowerLabel" style="-fx-font-size: 12px;" text="• One lowercase letter" />
                        <Label fx:id="ruleDigitLabel" style="-fx-font-size: 12px;" text="• One number" />
                        <Label fx:id="ruleSpecialLabel" style="-fx-font-size: 12px;" text="• One special character" />
                    </VBox>
                </VBox>
            </VBox>

            <VBox spacing="10.0">

                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Confirm Password" />

                <!-- CONFIRM PASSWORD WITH TOGGLE -->
                <StackPane maxWidth="1.7976931348623157E308">
                    <children>
                        <PasswordField fx:id="confirmPasswordField" prefHeight="42" style="-fx-background-radius: 8; -fx-border-radius: 8;" />
                        <TextField fx:id="confirmPasswordVisibleField" managed="false" prefHeight="42" style="-fx-background-radius: 8; -fx-border-radius: 8;" visible="false" />

                        <Button fx:id="toggleConfirmPasswordButton" focusTraversable="false" onAction="#handleToggleConfirmPassword" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 14px;" text="👁" StackPane.alignment="CENTER_RIGHT">
                            <StackPane.margin>
                                <Insets right="10.0" />
                            </StackPane.margin>
                        </Button>
                    </children>
                </StackPane>

                <Label fx:id="passwordMatchLabel" style="-fx-font-size: 12px;" text="" />
            </VBox>

            <HBox alignment="CENTER" spacing="12">
                <Button fx:id="updatePasswordButton" disable="true" onAction="#handleChangePassword" prefHeight="42" prefWidth="220" style="-fx-background-color: #b0b0b0;                -fx-text-fill: white;                -fx-font-weight: bold;                -fx-background-radius: 22;                -fx-cursor: default;" text="Update Password" />

                <ProgressIndicator fx:id="loadingSpinner" managed="false" prefHeight="22" prefWidth="22" visible="false" />
            </HBox>

        </VBox>

    </children>

    <padding>
        <Insets bottom="8" left="8" right="8" top="8" />
    </padding>
</VBox>

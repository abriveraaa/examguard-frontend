<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="24"
      style="-fx-background-color: transparent;"
      alignment="TOP_CENTER">

    <children>

        <!-- ACCOUNT INFO CARD -->
        <VBox spacing="18"
              maxWidth="900"
              style="-fx-background-color: white;
                     -fx-background-radius: 16;
                     -fx-padding: 28;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4);">

            <Label text="Profile Settings"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #302C29;" />

            <Label text="Manage your account information and password."
                   style="-fx-font-size: 13px; -fx-text-fill: #666666;" />

            <Separator />

            <VBox spacing="14">
                <Label text="Username"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #555555;" />
                <TextField fx:id="usernameField"
                           editable="false"
                           prefHeight="42"
                           style="-fx-background-radius: 8; -fx-border-radius: 8;" />

                <Label text="Email"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #555555;" />
                <TextField fx:id="emailField"
                           prefHeight="42"
                           style="-fx-background-radius: 8; -fx-border-radius: 8;" />
            </VBox>
        </VBox>

        <!-- PASSWORD CARD -->
        <VBox spacing="18"
              maxWidth="900"
              style="-fx-background-color: white;
                     -fx-background-radius: 16;
                     -fx-padding: 28;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4);">

            <Label text="Change Password"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #302C29;" />

            <Label fx:id="mustChangeLabel"
                   text="You must change your temporary password before continuing."
                   wrapText="true"
                   style="-fx-text-fill: #b91c1c; -fx-font-weight: bold; -fx-font-size: 13px;" />

            <VBox spacing="14">
                <Label text="Current Password"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #555555;" />
                <PasswordField fx:id="currentPasswordField"
                               prefHeight="42"
                               style="-fx-background-radius: 8; -fx-border-radius: 8;" />

                <Label text="New Password"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #555555;" />
                <PasswordField fx:id="newPasswordField"
                               prefHeight="42"
                               style="-fx-background-radius: 8; -fx-border-radius: 8;" />

                <Label text="Confirm Password"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #555555;" />
                <PasswordField fx:id="confirmPasswordField"
                               prefHeight="42"
                               style="-fx-background-radius: 8; -fx-border-radius: 8;" />
            </VBox>

            <Label fx:id="errorLabel"
                   wrapText="true"
                   style="-fx-text-fill: red; -fx-font-size: 12px;" />

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button fx:id="updatePasswordButton"
                        text="Update Password"

                        prefHeight="42"
                        prefWidth="220"
                        style="-fx-background-color: #650000;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 22;
                               -fx-cursor: hand;" />

                <ProgressIndicator fx:id="loadingSpinner"
                                   visible="false"
                                   managed="false"
                                   prefHeight="22"
                                   prefWidth="22" />
            </HBox>
        </VBox>

    </children>

    <padding>
        <Insets top="8" right="8" bottom="8" left="8"/>
    </padding>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane minWidth="900.0"
            style="-fx-background-color: #650000;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.examguard.controller.auth.LoginController">

    <StackPane AnchorPane.bottomAnchor="0"
               AnchorPane.leftAnchor="0"
               AnchorPane.rightAnchor="0"
               AnchorPane.topAnchor="0">

        <HBox alignment="CENTER" maxHeight="600" maxWidth="1000" spacing="80" style="-fx-padding: 60;">

            <!-- LEFT BRAND -->
            <VBox alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS">

                <Label style="-fx-text-fill: white; -fx-font-size: 54px; -fx-font-weight: bold;" text="ExamGuard" wrapText="true" />

                <Label alignment="CENTER" prefWidth="264" style="-fx-text-fill: #f2f2f2; -fx-font-size: 15px;" text="Secure Examination System for PUP" textAlignment="CENTER" />
            </VBox>

            <!-- LOGIN CARD -->
            <VBox alignment="CENTER"
                  maxHeight="450"
                  maxWidth="380"
                  minHeight="480.0"
                  minWidth="380.0"
                  spacing="14"
                  style="-fx-background-color: white; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 25, 0, 0, 10);">

                <padding>
                    <Insets bottom="45" left="45" right="45" top="45" />
                </padding>

                <!-- HEADER -->
                <Label style="-fx-font-size: 26px; -fx-font-weight: bold;" text="Log in" />

                <!-- USERNAME -->
                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #666;" text="Username">
                  <font>
                     <Font name="System Bold" size="18.0" />
                  </font></Label>

                    <TextField fx:id="usernameField" maxWidth="300" prefHeight="48" promptText="Enter your username" style="-fx-background-radius: 10; -fx-font-size: 14px;" />
                </VBox>

                <!-- PASSWORD -->
                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #666;" text="Password" />

                    <PasswordField fx:id="passwordField" maxWidth="300" prefHeight="48" promptText="Enter your password" style="-fx-background-radius: 10; -fx-font-size: 14px;" />
                </VBox>

                <!-- ERROR -->
                <Label fx:id="errorLabel"  style="-fx-text-fill: red; -fx-font-size: 12px;" textAlignment="CENTER" wrapText="true" HBox.hgrow="ALWAYS" />

                <!-- LOGIN -->
                <Button fx:id="loginButton"
                        maxWidth="300"
                        prefHeight="48"
                        onAction="#login"
                        text="LOGIN"
                        alignment="CENTER"
                        style="-fx-background-color: #650000; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 25; -fx-cursor: hand;">

                    <graphic>
                        <ProgressIndicator fx:id="loginSpinner" visible="false" managed="false" prefWidth="18" prefHeight="18" style="-fx-progress-color: white;"/>
                    </graphic>

                </Button>

                <!-- ACTIVATE ACCOUNT -->
                <HBox alignment="CENTER" spacing="5">
                    <Label style="-fx-text-fill: #666; -fx-font-size: 13px;" text="No account?" />

                    <Button onAction="#switchPage"
                            userData="activate"
                            style="-fx-background-color: transparent; -fx-text-fill: #650000; -fx-font-weight: bold; -fx-cursor: hand;"
                            text="Activate Account" />
                </HBox>

                <!-- FORGOT -->
                <Label text="Forgot Password?"
                       onMouseClicked="#switchPage"
                       userData="forgot"
                       style="-fx-text-fill: #3b82f6; -fx-underline: true; -fx-cursor: hand;" />
            </VBox>
        </HBox>
    </StackPane>
</AnchorPane>

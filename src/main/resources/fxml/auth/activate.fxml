<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane minWidth="900.0" style="-fx-background-color: #650000;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.examguard.controller.auth.ActivateAccountController">

    <StackPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <HBox alignment="CENTER" maxHeight="600" maxWidth="1000" spacing="80" style="-fx-padding: 60;">

            <!-- LEFT BRAND -->
            <VBox alignment="CENTER" spacing="12">

                <Label style="-fx-text-fill: white; -fx-font-size: 54px; -fx-font-weight: bold;" text="ExamGuard" />

                <Label style="-fx-text-fill: #f2f2f2; -fx-font-size: 15px;" text="Activate your account" />

            </VBox>

            <!-- SIGNUP CARD -->
            <VBox alignment="CENTER" maxWidth="380" minHeight="550.0" minWidth="380.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 25, 0, 0, 10);">


                <Label style="-fx-font-size: 26px; -fx-font-weight: bold;" text="Activate your Account" textAlignment="CENTER" />
            <Pane minHeight="20.0" prefHeight="10.0" />

                <!-- USER ID (student/employee ID) -->
                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #666;" text="Student ID / Employee ID">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font></Label>

                    <TextField fx:id="userIdField" prefHeight="48" promptText="Enter your Student ID / Employee ID" style="-fx-background-radius: 5;">
                  <font>
                     <Font size="14.0" />
                  </font></TextField>
                </VBox>

                <!-- EMAIL -->
<!--                <TextField fx:id="emailField" maxWidth="300" prefHeight="40" promptText="Email"/>-->

                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #666;" text="Email">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font></Label>

                    <TextField fx:id="emailField" prefHeight="48" promptText="Enter your email" style="-fx-background-radius: 5;">
                  <font>
                     <Font size="14.0" />
                  </font></TextField>
                </VBox>

                <!-- BIRTHDAY -->


                <VBox alignment="CENTER_LEFT" spacing="5">
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #666;" text="Birthday">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font></Label>

                    <DatePicker fx:id="birthdayField" editable="true" maxWidth="300" prefHeight="40" promptText="MM/dd/yyyy" style="-fx-background-radius: 5; -fx-border-radius: 5;" />
                </VBox>

                <ProgressIndicator fx:id="loadingSpinner" managed="false" visible="false" />
                <!-- ERROR -->
                <Label fx:id="errorLabel" style="-fx-text-fill: red; -fx-font-size: 12px;" textAlignment="CENTER" wrapText="true" HBox.hgrow="ALWAYS" />


                <!-- SIGNUP BUTTON -->
                <Button fx:id="signupButton" maxWidth="300" onAction="#handleSignup" prefHeight="45" style="-fx-background-color: #650000; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;                                -fx-background-radius: 25;                                -fx-cursor: hand;" text="ACTIVATE" />

                <!-- BACK TO LOGIN -->
                <Button onAction="#goToLogin" style="-fx-background-color: transparent; -fx-text-fill: #650000; -fx-cursor: hand;" text="Back to Login" />

                <padding>
                    <Insets bottom="20.0" left="45.0" right="45.0" top="20.0" />
                </padding>

            </VBox>

        </HBox>

    </StackPane>

</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="900.0" prefWidth="1440.0" style="-fx-background-color: #F5F5F5;" stylesheets="@/styles/admin-page.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.examguard.controller.layout.DashboardShellController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="74.0" spacing="20.0" style="-fx-background-color: #302C29; -fx-padding: 12 24;">

            <children>

                <Label style="-fx-font-size: 18px;-fx-font-weight: bold; -fx-font-family: 'Segoe UI';" text="ExamGuard" textFill="WHITE" />

                <Separator maxHeight="30.0" minHeight="30.0" orientation="VERTICAL" />

                <Region HBox.hgrow="ALWAYS" />

                <HBox fx:id="navContainer" alignment="CENTER_RIGHT" spacing="20.0" />

                <MenuButton style="-fx-background-color: transparent;" text="">
                    <graphic>
                        <StackPane style="-fx-background-color: white;                                           -fx-background-radius: 5;                                           -fx-min-width: 35;                                           -fx-min-height: 30;                                           -fx-max-width: 35;                                           -fx-max-height: 30;">
                            <Label fx:id="avatarLabel" style="-fx-text-fill: #2c3e50;                                           -fx-font-size: 16px;                                           -fx-font-weight: bold;                                           -fx-font-family: 'Segoe UI';" text="A" />
                        </StackPane>
                    </graphic>

                    <items>
                        <MenuItem onAction="#handleViewProfile" text="View Profile" />
                        <MenuItem onAction="#handleChangePasswordMenu" text="Change Password" />
                        <MenuItem onAction="#handleLogout" text="Logout" />
                    </items>
                </MenuButton>

            </children>
        </HBox>
    </top>

    <center>
        <VBox maxHeight="Infinity" maxWidth="Infinity" style="-fx-background-color: #F5F5F5;">

            <!-- HERO -->
            <StackPane fx:id="heroPane" maxHeight="200.0" minHeight="150.0" prefHeight="230.0">

                <children>

                    <ImageView fx:id="bannerImage" fitHeight="220.0" preserveRatio="true" StackPane.alignment="CENTER_RIGHT">
                        <Image url="@/images/banner-background-pin.png" />
                    </ImageView>

                    <Pane style="-fx-background-color: linear-gradient(to right,                                             rgba(101,0,0,0.94),                                             rgba(128,0,0,0.88),                                             rgba(128,0,0,0.83));" />

                    <VBox alignment="CENTER_LEFT" maxWidth="Infinity" prefWidth="1440.0" spacing="6" style="-fx-padding: 0 28 0 28;">

                        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="24.0">

                            <!-- LEFT SIDE -->
                            <VBox alignment="CENTER_LEFT" spacing="10.0" HBox.hgrow="ALWAYS">

                                <Label fx:id="greetingTitleLabel" style="-fx-font-size: 30px;                           -fx-font-weight: bold;                           -fx-text-fill: #F4D27A;                           -fx-font-family: 'Segoe UI';" />

                                <Label fx:id="greetingSubtitleLabel" maxWidth="560.0" style="-fx-font-size: 14px;                           -fx-text-fill: rgba(255,255,255,0.92);                           -fx-font-family: 'Segoe UI';" wrapText="true" />
                            </VBox>

                            <!-- RIGHT SIDE: DYNAMIC HERO CARDS -->
                            <HBox fx:id="heroCardsContainer" alignment="CENTER_RIGHT" maxHeight="100.0" spacing="15.0" />
                        </HBox>

                        <!-- FILTERS BELOW CARDS -->
                        <HBox fx:id="heroControlsContainer" alignment="CENTER_RIGHT" managed="false" spacing="10" styleClass="hero-controls-row" visible="false" />
                    </VBox>

                </children>
            </StackPane>

            <!-- DYNAMIC PAGE CONTENT -->
            <StackPane fx:id="contentHolder" maxHeight="Infinity" maxWidth="Infinity" style="-fx-padding: 16 16 16 16; -fx-background-color: rgb(251, 249, 248);" VBox.vgrow="ALWAYS" />

        </VBox>
    </center>

</BorderPane>

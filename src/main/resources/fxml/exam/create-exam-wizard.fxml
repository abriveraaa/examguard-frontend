<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<StackPane fx:id="wizardRoot"
           xmlns:fx="http://javafx.com/fxml/1"
           prefHeight="720"
           prefWidth="1080"
           stylesheets="/styles/exam-wizard.css"
           xmlns="http://javafx.com/javafx/17.0.12"
           fx:controller="com.example.examguard.controller.exam.CreateExamController">

    <BorderPane styleClass="wizard-root">

    <center>
        <StackPane styleClass="wizard-content">

            <!-- STEP 1 -->
            <VBox fx:id="stepOnePane" spacing="14" styleClass="create-exam-page">

                <HBox alignment="CENTER_LEFT" styleClass="page-intro-card">
                    <VBox spacing="3">
                        <Label styleClass="page-intro-title" text="Create Exam"/>
                        <Label styleClass="page-intro-subtitle"
                               text="Complete the basic exam details before adding questions."/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label fx:id="stepChipLabel" styleClass="step-chip" text="Step 1 of 3"/>
                </HBox>

                <GridPane hgap="16" vgap="16" VBox.vgrow="ALWAYS">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="62"/>
                        <ColumnConstraints percentWidth="38"/>
                    </columnConstraints>

                    <!-- LEFT COLUMN -->
                    <VBox spacing="14" GridPane.columnIndex="0">

                        <!-- EXAM DETAILS -->
                        <VBox spacing="10" styleClass="modern-card">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="2">
                                    <Label styleClass="card-title" text="Exam Details"/>
                                    <Label styleClass="card-subtitle"
                                           text="Name the exam and provide short instructions."/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label styleClass="required-chip" text="Required"/>
                            </HBox>

                            <VBox spacing="4">
                                <Label styleClass="field-label" text="Exam Title"/>
                                <TextField fx:id="titleField"
                                           promptText="Example: Midterm Examination"
                                           styleClass="modern-input"/>
                                <Label fx:id="titleErrorLabel" styleClass="field-error-text" text=""/>
                            </VBox>

                            <VBox spacing="4">
                                <Label styleClass="field-label" text="Description / Instructions"/>
                                <TextArea fx:id="descriptionArea" prefRowCount="3"
                                          promptText="Example: Read each question carefully. You have one attempt only."
                                          styleClass="modern-textarea" wrapText="true"/>
                            </VBox>
                        </VBox>

                        <!-- ASSIGNMENT -->
                        <VBox spacing="10" styleClass="modern-card" VBox.vgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="2">
                                    <Label styleClass="card-title" text="Assign Exam"/>
                                    <Label styleClass="card-subtitle"
                                           text="Choose the class offering that will receive this exam."/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="selectedClassOfferingLabel" styleClass="selected-chip"
                                       text="No class selected"/>
                            </HBox>

                            <TextField fx:id="classOfferingSearchField"
                                       promptText="Search by course, section, program, or year..."
                                       styleClass="modern-input"/>

                            <ListView fx:id="classOfferingListView" prefHeight="120" styleClass="modern-list"
                                      VBox.vgrow="ALWAYS"/>

                            <Label fx:id="classErrorLabel" styleClass="field-error-text" text=""/>
                        </VBox>

                    </VBox>

                    <!-- RIGHT COLUMN -->
                    <VBox spacing="14" GridPane.columnIndex="1">

                        <!-- SCHEDULE -->
                        <VBox spacing="10" styleClass="modern-card accent-card">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="2">
                                    <Label styleClass="card-title" text="Schedule"/>
                                    <Label styleClass="card-subtitle" text="Set exam availability."/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label styleClass="timezone-chip" text="Asia/Manila"/>
                            </HBox>

                            <VBox spacing="4">
                                <Label styleClass="field-label" text="Duration"/>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Spinner fx:id="durationSpinner" editable="true" prefWidth="125"
                                             styleClass="modern-spinner"/>
                                    <Label styleClass="helper-text" text="minutes"/>
                                </HBox>
                                <Label fx:id="durationErrorLabel" styleClass="field-error-text" text=""/>
                            </VBox>

                            <GridPane hgap="10" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50"/>
                                    <ColumnConstraints percentWidth="50"/>
                                </columnConstraints>

                                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label styleClass="field-label" text="Start Date"/>
                                    <DatePicker fx:id="startDatePicker" maxWidth="Infinity" promptText="Date"
                                                styleClass="modern-input"/>
                                </VBox>

                                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label styleClass="field-label" text="Start Time"/>
                                    <ComboBox fx:id="startTimeCombo" maxWidth="Infinity" promptText="Time"
                                              styleClass="modern-input"/>
                                </VBox>

                                <Label fx:id="startErrorLabel" styleClass="field-error-text" text=""
                                       GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1"/>

                                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                    <Label styleClass="field-label" text="End Date"/>
                                    <DatePicker fx:id="endDatePicker" maxWidth="Infinity" promptText="Date"
                                                styleClass="modern-input"/>
                                </VBox>

                                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <Label styleClass="field-label" text="End Time"/>
                                    <ComboBox fx:id="endTimeCombo" maxWidth="Infinity" promptText="Time"
                                              styleClass="modern-input"/>
                                </VBox>

                                <Label fx:id="endErrorLabel" styleClass="field-error-text" text=""
                                       GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="3"/>
                                <rowConstraints>
                                    <RowConstraints/>
                                    <RowConstraints/>
                                    <RowConstraints/>
                                    <RowConstraints/>
                                </rowConstraints>
                            </GridPane>
                        </VBox>

                        <!-- SETTINGS -->
                        <VBox spacing="10" styleClass="modern-card" VBox.vgrow="ALWAYS">
                            <VBox spacing="2">
                                <Label styleClass="card-title" text="Exam Behavior"/>
                                <Label styleClass="card-subtitle" text="Control how the exam will be delivered."/>
                            </VBox>

                            <VBox spacing="4">
                                <Label styleClass="field-label" text="Exam Mode"/>
                                <HBox spacing="8">
                                    <RadioButton fx:id="asyncModeRadio" styleClass="pill-radio" text="Asynchronous"/>
                                    <RadioButton fx:id="syncModeRadio" styleClass="pill-radio" text="Synchronous"/>
                                </HBox>
                                <Label fx:id="modeErrorLabel" styleClass="field-error-text" text=""/>
                            </VBox>

                            <HBox spacing="8">
                                <CheckBox fx:id="shuffleQuestionsCheck" styleClass="modern-check"
                                          text="Shuffle question order"/>

                                <CheckBox fx:id="shuffleChoicesCheck" styleClass="modern-check" text="Shuffle choices"/>
                            </HBox>

                            <Separator/>

                            <VBox spacing="10" styleClass="modern-card" VBox.vgrow="ALWAYS">

                                <VBox spacing="2">
                                    <Label styleClass="card-title" text="Question Source"/>
                                    <Label styleClass="card-subtitle"
                                           text="Upload your questions or create them manually in the next step. "/>
                                </VBox>

                                <!-- UPLOAD AREA -->
                                <HBox alignment="CENTER_LEFT" spacing="8">

                                    <Button fx:id="uploadButton" onAction="#handleUploadTemplate"
                                            styleClass="upload-button" text="Upload Excel"/>

                                    <Label fx:id="downloadTemplateLabel"
                                           onMouseClicked="#handleDownloadTemplate"
                                           styleClass="link-label"
                                           text="Download template"/>
                                </HBox>

                                <Label fx:id="uploadStatusLabel" styleClass="helper-text" text="No file uploaded"/>

                            </VBox>
                        </VBox>

                    </VBox>
                    <rowConstraints>
                        <RowConstraints/>
                    </rowConstraints>
                </GridPane>

                <Label fx:id="stepOneMessageLabel" styleClass="message-label" text="" wrapText="true"/>

            </VBox>

            <!-- STEP 2 -->
            <VBox fx:id="stepTwoPane" managed="false" visible="false" spacing="18" styleClass="step-content">

                <VBox spacing="4">
                    <Label text="Step 2" styleClass="step-kicker"/>
                    <Label text="Build Questions" styleClass="step-title"/>
                    <Label text="Add, edit, and review the questions included in this exam."
                           styleClass="step-subtitle"/>
                </VBox>

                <HBox spacing="18" VBox.vgrow="ALWAYS">

                    <!-- LEFT PANEL -->
                    <VBox spacing="12" styleClass="question-list-panel" prefWidth="320">

                        <HBox alignment="CENTER_LEFT">
                            <VBox HBox.hgrow="ALWAYS">
                                <Label text="Questions" styleClass="panel-title"/>
                                <Label fx:id="questionCountLabel"
                                       text="0 questions added"
                                       styleClass="panel-subtitle"/>
                            </VBox>

                            <Button text="+ Add"
                                    onAction="#handleAddQuestion"
                                    styleClass="primary-small-button"/>
                        </HBox>

                        <ListView fx:id="questionListView"
                                  VBox.vgrow="ALWAYS"
                                  styleClass="modern-list-view"/>

                        <HBox spacing="8">
                            <Button text="Up"
                                    onAction="#handleMoveQuestionUp"
                                    styleClass="outline-small-button"/>
                            <Button text="Down"
                                    onAction="#handleMoveQuestionDown"
                                    styleClass="outline-small-button"/>
                            <Button text="Duplicate"
                                    onAction="#handleDuplicateQuestion"
                                    styleClass="outline-small-button"/>
                            <Button text="Delete"
                                    onAction="#handleDeleteQuestion"
                                    styleClass="danger-small-button"/>
                        </HBox>

                    </VBox>

                    <!-- RIGHT PANEL -->
                    <ScrollPane fitToWidth="true"
                                hbarPolicy="NEVER"
                                vbarPolicy="AS_NEEDED"
                                HBox.hgrow="ALWAYS"
                                styleClass="step-scroll-pane">

                        <VBox spacing="16"
                              styleClass="question-editor-panel"
                              prefWidth="700">

                            <HBox alignment="CENTER_LEFT">
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label fx:id="editorTitleLabel"
                                           text="Question Editor"
                                           styleClass="panel-title"/>
                                    <Label fx:id="editorSubtitleLabel"
                                           text="Select a question or add a new one."
                                           styleClass="panel-subtitle"/>
                                </VBox>

                                <Label fx:id="questionStatusBadge"
                                       text="Not Started"
                                       styleClass="status-badge warning-badge"/>
                            </HBox>

                            <GridPane hgap="14" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50"/>
                                    <ColumnConstraints percentWidth="50"/>
                                </columnConstraints>

                                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="Question Type" styleClass="field-label"/>
                                    <ComboBox fx:id="questionTypeComboBox"
                                              promptText="Select type"
                                              maxWidth="Infinity"
                                              styleClass="modern-combo"/>
                                </VBox>

                                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label text="Points" styleClass="field-label"/>
                                    <TextField fx:id="pointsField"
                                               promptText="Example: 1"
                                               styleClass="modern-input"/>
                                </VBox>
                            </GridPane>

                            <!-- Image toggle must be above question text -->
                            <CheckBox fx:id="useImagesCheckBox"
                                      text="This question uses images"
                                      styleClass="image-toggle-check"/>

                            <!-- Question text -->
                            <VBox spacing="6">
                                <Label text="Question Text" styleClass="field-label"/>
                                <TextArea fx:id="questionTextArea"
                                          promptText="Enter the question here..."
                                          wrapText="true"
                                          prefRowCount="4"
                                          styleClass="modern-textarea"/>
                            </VBox>

                            <!-- Question image should stay here, below question text -->
                            <VBox fx:id="questionImageContainer"
                                  spacing="8"
                                  visible="false"
                                  managed="false"/>

                            <!-- Answers only -->
                            <VBox spacing="8">
                                <Label text="Answer Details" styleClass="panel-title"/>
                                <VBox fx:id="dynamicAnswerContainer"
                                      spacing="12"
                                      styleClass="answer-container"
                                      VBox.vgrow="ALWAYS"/>
                            </VBox>

                            <HBox alignment="CENTER_RIGHT" spacing="10">
                                <Label fx:id="validationLabel"
                                       text=""
                                       styleClass="validation-label"
                                       HBox.hgrow="ALWAYS"/>

                                <Button text="Clear"
                                        onAction="#handleClearQuestionEditor"
                                        styleClass="ghost-button"/>

                                <Button text="Save Question"
                                        onAction="#handleSaveQuestion"
                                        styleClass="primary-button"/>
                            </HBox>

                        </VBox>
                    </ScrollPane>

                </HBox>

            </VBox>

            <!-- STEP 3 -->
            <VBox fx:id="stepThreePane" spacing="18" styleClass="step-content">

                <VBox spacing="4">
                    <Label text="Violation Settings" styleClass="step-title" />
                    <Label text="Configure exam-level monitoring rules. Per-question overrides are prepared for future rule expansion."
                           styleClass="step-subtitle" />
                </VBox>

                <HBox spacing="18" VBox.vgrow="ALWAYS">

                    <VBox spacing="14" HBox.hgrow="ALWAYS" styleClass="violation-card">

                        <VBox spacing="4">
                            <Label text="Exam-Level Rules" styleClass="card-title" />
                            <Label text="0 allowed means the first attempt is already recorded as a violation."
                                   styleClass="card-subtitle" />
                        </VBox>

                        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="violation-header-row">
                            <Label text="Rule" styleClass="violation-header" prefWidth="250" />
                            <Label text="Severity" styleClass="violation-header" prefWidth="135" />
                            <Label text="Allowed" styleClass="violation-header" prefWidth="90" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="violation-row">
                            <CheckBox fx:id="focusLostViolationCheck" text="Focus Lost / App Switching" prefWidth="250" styleClass="modern-check" />
                            <ComboBox fx:id="focusLostSeverityCombo" prefWidth="135" styleClass="modern-combo" />
                            <Spinner fx:id="focusLostLimitSpinner" prefWidth="90" editable="true" styleClass="modern-spinner violation-spinner" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="violation-row">
                            <CheckBox fx:id="fullscreenExitViolationCheck" text="Fullscreen Exit" prefWidth="250" styleClass="modern-check" />
                            <ComboBox fx:id="fullscreenExitSeverityCombo" prefWidth="135" styleClass="modern-combo" />
                            <Spinner fx:id="fullscreenExitLimitSpinner" prefWidth="90" editable="true" styleClass="modern-spinner violation-spinner" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="violation-row">
                            <CheckBox fx:id="windowMinimizeViolationCheck" text="Window Minimized" prefWidth="250" styleClass="modern-check" />
                            <ComboBox fx:id="windowMinimizeSeverityCombo" prefWidth="135" styleClass="modern-combo" />
                            <Spinner fx:id="windowMinimizeLimitSpinner" prefWidth="90" editable="true" styleClass="modern-spinner violation-spinner" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="violation-row">
                            <CheckBox fx:id="restrictedKeysViolationCheck" text="Restricted Keyboard Shortcuts" prefWidth="250" styleClass="modern-check" />
                            <ComboBox fx:id="restrictedKeysSeverityCombo" prefWidth="135" styleClass="modern-combo" />
                            <Spinner fx:id="restrictedKeysLimitSpinner" prefWidth="90" editable="true" styleClass="modern-spinner violation-spinner" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="violation-row">
                            <CheckBox fx:id="rightClickViolationCheck" text="Right Click" prefWidth="250" styleClass="modern-check" />
                            <ComboBox fx:id="rightClickSeverityCombo" prefWidth="135" styleClass="modern-combo" />
                            <Spinner fx:id="rightClickLimitSpinner" prefWidth="90" editable="true" styleClass="modern-spinner violation-spinner" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="violation-row">
                            <CheckBox fx:id="multipleMonitorsViolationCheck" text="Multiple Monitors" prefWidth="250" styleClass="modern-check" />
                            <ComboBox fx:id="multipleMonitorsSeverityCombo" prefWidth="135" styleClass="modern-combo" />
                            <Spinner fx:id="multipleMonitorsLimitSpinner" prefWidth="90" editable="true" styleClass="modern-spinner violation-spinner" />
                        </HBox>

                    </VBox>

                    <VBox spacing="14" prefWidth="340" styleClass="violation-card">

                        <VBox spacing="4">
                            <Label text="Global Actions" styleClass="card-title" />
                            <Label text="These settings decide what happens when violations accumulate."
                                   styleClass="card-subtitle" />
                        </VBox>

                        <VBox spacing="8" styleClass="violation-threshold-box">
                            <Label text="Warning Threshold" styleClass="field-label" />
                            <Spinner fx:id="warningThresholdSpinner" editable="true" prefWidth="130" styleClass="modern-spinner" />
                            <Label text="0 means show warning immediately after the first recorded violation."
                                   wrapText="true" styleClass="helper-text" />
                        </VBox>

                        <VBox spacing="8" styleClass="violation-threshold-box">
                            <Label text="Major Threshold" styleClass="field-label" />
                            <Spinner fx:id="majorThresholdSpinner" editable="true" prefWidth="130" styleClass="modern-spinner" />
                            <Label text="0 means mark the attempt high-risk after the first recorded violation."
                                   wrapText="true" styleClass="helper-text" />
                        </VBox>

                        <VBox spacing="8" styleClass="violation-threshold-box">
                            <Label text="Auto-submit Threshold" styleClass="field-label" />
                            <Spinner fx:id="autoSubmitThresholdSpinner" editable="true" prefWidth="130" styleClass="modern-spinner" />
                            <Label text="0 means auto-submit is disabled."
                                   wrapText="true" styleClass="helper-text" />
                        </VBox>

                        <VBox spacing="6" styleClass="violation-info-card">
                            <Label text="Severity Guide" styleClass="violation-info-title" />
                            <Label text="Minor: recorded only&#10;Major: warning + flagged attempt&#10;Critical: high-risk and may trigger auto-submit"
                                   wrapText="true"
                                   styleClass="violation-info-text" />
                        </VBox>

                    </VBox>

                </HBox>

            </VBox>

            <!-- STEP 4 -->
            <VBox fx:id="stepFourPane" managed="false" visible="false" spacing="18" styleClass="step-content">

                <VBox spacing="4">
                    <Label text="Step 4" styleClass="step-kicker"/>
                    <Label text="Summary" styleClass="step-title"/>
                    <Label text="Review the exam details before saving as draft or publishing."
                           styleClass="step-subtitle"/>
                </VBox>

                <ScrollPane fitToWidth="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            styleClass="step-scroll-pane"
                            VBox.vgrow="ALWAYS">

                    <VBox spacing="18">

                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>

                            <VBox spacing="10"
                                  styleClass="review-card"
                                  GridPane.columnIndex="0"
                                  GridPane.rowIndex="0">

                                <Label text="Exam Information" styleClass="panel-title"/>

                                <Label text="Title" styleClass="review-label"/>
                                <Label fx:id="reviewTitleLabel" styleClass="review-value" wrapText="true"/>

                                <Label text="Duration" styleClass="review-label"/>
                                <Label fx:id="reviewDurationLabel" styleClass="review-value"/>

                                <Label text="Schedule" styleClass="review-label"/>
                                <Label fx:id="reviewScheduleLabel" styleClass="review-value" wrapText="true"/>
                            </VBox>

                            <VBox spacing="10"
                                  styleClass="review-card"
                                  GridPane.columnIndex="1"
                                  GridPane.rowIndex="0">

                                <Label text="Assignment &amp; Settings" styleClass="panel-title"/>

                                <Label text="Class Offering" styleClass="review-label"/>
                                <Label fx:id="reviewClassOfferingLabel" styleClass="review-value" wrapText="true"/>

                                <Label text="Questions" styleClass="review-label"/>
                                <Label fx:id="reviewQuestionCountLabel" styleClass="review-value"/>

                                <Label text="Shuffle Questions" styleClass="review-label"/>
                                <Label fx:id="reviewShuffleQuestionsLabel" styleClass="review-value"/>

                                <Label text="Shuffle Choices" styleClass="review-label"/>
                                <Label fx:id="reviewShuffleChoicesLabel" styleClass="review-value"/>
                            </VBox>
                        </GridPane>

                        <VBox spacing="12" styleClass="review-card">
                            <HBox alignment="CENTER_LEFT">
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label text="Question Preview" styleClass="panel-title"/>
                                    <Label text="Check question content, images, choices, points, and correct answers."
                                           styleClass="panel-subtitle"/>
                                </VBox>

                                <Label fx:id="reviewValidationBadge"
                                       text="Ready"
                                       styleClass="review-ready-badge"/>
                            </HBox>

                            <VBox fx:id="reviewQuestionContainer"
                                  spacing="12"/>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </VBox>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="wizard-footer">

            <!-- LEFT SIDE (Cancel) -->
            <Button onAction="#handleCancel"
                    styleClass="ghost-button"
                    text="Cancel"/>

            <!-- PUSH EVERYTHING ELSE TO RIGHT -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- RIGHT SIDE (Navigation) -->
            <Button fx:id="backButton"
                    disable="true"
                    onAction="#handleBack"
                    styleClass="outline-button"
                    text="Back"/>

            <Button fx:id="nextButton"
                    onAction="#handleNext"
                    styleClass="primary-button"
                    text="Next"/>

            <Button fx:id="draftButton"
                    managed="false"
                    onAction="#handleSaveDraft"
                    styleClass="outline-button"
                    text="Save as Draft"
                    visible="false">
                <graphic>
                    <ProgressIndicator fx:id="draftSpinner" visible="false" managed="false" prefWidth="18" prefHeight="18" style="-fx-progress-color: white;"/>
                </graphic>

            </Button>

            <Button fx:id="publishButton"
                    managed="false"
                    onAction="#handlePublish"
                    styleClass="primary-button"
                    text="Publish"
                    visible="false">
                <graphic>
                    <ProgressIndicator fx:id="publishSpinner" visible="false" managed="false" prefWidth="18" prefHeight="18" style="-fx-progress-color: white;"/>
                </graphic>

            </Button>

            <padding>
                <Insets bottom="10.0" right="10.0" top="10.0"/>
            </padding>

        </HBox>
    </bottom>
    </BorderPane>

</StackPane>

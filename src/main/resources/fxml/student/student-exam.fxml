<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.examguard.controller.student.StudentExamListController"
            stylesheets="/styles/student-exams.css"
            styleClass="page-root">

    <top>
        <VBox spacing="6" styleClass="page-header">
            <Label text="My Exams" styleClass="page-title"/>
            <Label text="View and take your assigned exams." styleClass="page-subtitle"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="14" styleClass="content-area">
            <TableView fx:id="examTable" styleClass="modern-table">
                <columns>
                    <TableColumn fx:id="titleColumn" text="Exam Title" prefWidth="280"/>
                    <TableColumn fx:id="courseColumn" text="Course" prefWidth="120"/>
                    <TableColumn fx:id="scheduleColumn" text="Schedule" prefWidth="230"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
                    <TableColumn fx:id="questionsColumn" text="Questions" prefWidth="90"/>
                    <TableColumn fx:id="timeColumn" text="Time Limit" prefWidth="100"/>
                    <TableColumn fx:id="actionColumn" text="Action" prefWidth="140"/>
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>
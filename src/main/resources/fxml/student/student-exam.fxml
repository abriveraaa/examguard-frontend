<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.examguard.controller.student.StudentExamsController"
            styleClass="student-exams-root"
            stylesheets="@../../styles/student-exam.css">

    <top>
        <VBox spacing="16" styleClass="student-exams-top">

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button fx:id="allButton" text="All" onAction="#filterAll" styleClass="exam-filter-active"/>
                <Button fx:id="upcomingButton" text="Upcoming" onAction="#filterUpcoming" styleClass="exam-filter-button"/>
                <Button fx:id="inProgressButton" text="In Progress" onAction="#filterOngoing" styleClass="exam-filter-button"/>
                <Button fx:id="submittedButton" text="Pending Review" onAction="#filterPendingReview" styleClass="exam-filter-button"/>
                <Button fx:id="resultsButton" text="Results Released" onAction="#filterResultsReleased" styleClass="exam-filter-button"/>
                <Button fx:id="missedButton" text="Did Not Take" onAction="#filterMissed" styleClass="exam-filter-button"/>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="14" alignment="CENTER_RIGHT" styleClass="student-exams-top-row">

                    <ComboBox fx:id="termComboBox"
                              promptText="Second Semester, AY 2025-2026"
                              styleClass="student-term-combo"/>

                    <TextField fx:id="searchField"
                               promptText="Search exams..."
                               styleClass="student-search-field"/>

                </HBox>
            </HBox>

        </VBox>
    </top>

    <center>
        <VBox spacing="12" styleClass="student-exams-panel">

            <ScrollPane fx:id="examScrollPane"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        styleClass="exam-card-scroll"
                        VBox.vgrow="ALWAYS">

                <TilePane fx:id="examCardGrid"
                          vgap="22"
                          alignment="TOP_LEFT"
                          tileAlignment="TOP_LEFT"
                          styleClass="exam-card-grid"/>
            </ScrollPane>

            <HBox alignment="CENTER_RIGHT" spacing="8" styleClass="exam-pagination-bar">
                <Button text="‹" onAction="#previousPage" styleClass="pagination-button"/>
                <Label fx:id="pageInfoLabel" text="Page 1" styleClass="pagination-label"/>
                <Button text="›" onAction="#nextPage" styleClass="pagination-button"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
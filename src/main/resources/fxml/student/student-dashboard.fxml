<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane styleClass="student-dashboard-root"
           stylesheets="@/styles/student-home.css"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.examguard.controller.student.StudentDashboardController">

    <HBox spacing="0" styleClass="student-dashboard-shell">

        <!-- LEFT PROFILE -->
        <VBox spacing="14" styleClass="student-profile-panel">

            <StackPane styleClass="student-profile-avatar">
                <ImageView fx:id="studentAvatarImageView"
                           fitHeight="72"
                           fitWidth="72"
                           managed="false"
                           preserveRatio="true"
                           visible="false" />

                <Label fx:id="studentInitialsLabel"
                       styleClass="student-profile-avatar-text"
                       text="ST" />
            </StackPane>

            <VBox alignment="CENTER" spacing="3">
                <Label fx:id="studentNameLabel"
                       styleClass="student-profile-name"
                       text=" " />

                <Label fx:id="studentEmailLabel"
                       styleClass="student-profile-email"
                       text=" " />

                <Label fx:id="studentIDLabel"
                       styleClass="student-profile-id"
                       text=" " />
            </VBox>

            <Separator />

            <VBox spacing="10" styleClass="student-info-box">
                <VBox spacing="3">
                    <Label styleClass="student-school-label" text="Program" />
                    <Label fx:id="studentProgramLabel"
                           styleClass="student-school-value"
                           text="Program"
                           wrapText="true" />
                </VBox>

                <VBox spacing="3">
                    <Label styleClass="student-school-label" text="College" />
                    <Label fx:id="studentCollegeLabel"
                           styleClass="student-school-value"
                           text="College"
                           wrapText="true" />
                </VBox>

                <VBox spacing="3">
                    <Label styleClass="student-school-label" text="Current Term" />
                    <Label fx:id="studentCurrentTermLabel"
                           styleClass="student-school-value"
                           text="Current Term"
                           wrapText="true" />
                </VBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Label onMouseClicked="#handleProfile" styleClass="student-profile-link" text="My Profile →" />

        </VBox>

        <!-- MAIN CONTENT -->
        <VBox styleClass="student-content-wrapper" HBox.hgrow="ALWAYS">

            <HBox spacing="18" styleClass="student-content-row" VBox.vgrow="ALWAYS">

                <!-- CENTER: UPCOMING EXAMS -->
                <VBox spacing="14" styleClass="student-main-section" HBox.hgrow="ALWAYS">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <VBox spacing="2">
                            <Label styleClass="student-section-title" text="Upcoming Exams" />
                            <Label styleClass="student-muted-text" text="Start available exams or review your schedule." />
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleReloadUpcomingExams"
                                styleClass="student-reload-button"
                                text="↻" />

                        <Label
                                fx:id="viewAllUpcomingExamsLabel"
                                styleClass="student-view-all"
                                text="View All →"
                        />

                    </HBox>

                    <Pane styleClass="student-gold-line" />

                    <VBox fx:id="upcomingExamList"
                          spacing="0"
                          styleClass="oracle-list"
                          VBox.vgrow="ALWAYS" />

                </VBox>

                <!-- RIGHT COLUMN -->
                <VBox spacing="18" styleClass="student-side-section">

                    <VBox spacing="12" styleClass="student-clean-box" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="2">
                                <Label styleClass="student-section-title-small" text="Violations" />
                                <Label styleClass="student-muted-text" text="Recent integrity alerts." />
                            </VBox>

                            <Region HBox.hgrow="ALWAYS" />

                            <Button onAction="#handleReloadViolations"
                                    styleClass="student-reload-button"
                                    text="↻" />

                            <Label
                                    fx:id="viewAllPendingReviewLabel"
                                    styleClass="student-view-all"
                                    text="View All →"
                            />
                        </HBox>

                        <Pane styleClass="student-gold-line" />

                        <VBox fx:id="violationList"
                              spacing="6"
                              styleClass="oracle-list" />

                    </VBox>

                    <VBox spacing="12" styleClass="student-clean-box" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="2">
                                <Label styleClass="student-section-title-small" text="Results" />
                                <Label styleClass="student-muted-text" text="Latest exam outcomes." />
                            </VBox>

                            <Region HBox.hgrow="ALWAYS" />

                            <Button onAction="#handleReloadResults"
                                    styleClass="student-reload-button"
                                    text="↻" />

                            <Label
                                    fx:id="viewAllResultsReleasedLabel"
                                    styleClass="student-view-all"
                                    text="View All →"
                            />
                        </HBox>

                        <Pane styleClass="student-gold-line" />

                        <VBox fx:id="resultSummaryList"
                              spacing="6"
                              styleClass="oracle-list" />
                    </VBox>

                </VBox>

            </HBox>

        </VBox>

    </HBox>

</StackPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.Image?>
<StackPane fx:id="examRoot"
           prefWidth="Infinity"
           prefHeight="Infinity"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.examguard.controller.student.ExamTakingController"
           stylesheets="/styles/exam-taking.css"
           styleClass="exam-root">

    <!-- EXAM LOBBY -->
    <StackPane fx:id="lobbyView"
               styleClass="lobby-shell-root">

        <HBox alignment="CENTER" fillHeight="true">

            <!-- LEFT BRANDING PANEL -->
            <StackPane HBox.hgrow="ALWAYS"
                       styleClass="lobby-brand-panel">

                <VBox alignment="CENTER"
                      spacing="18"
                      maxWidth="520"
                      styleClass="lobby-brand-content">

                    <ImageView fx:id="schoolLogoImageView"
                               fitWidth="255"
                               fitHeight="255"
                               preserveRatio="true"
                               smooth="true"
                               opacity="0.18"/>

                    <VBox alignment="CENTER" spacing="6">
                        <Label fx:id="brandSchoolNameLabel"
                               text="ExamGuard"
                               wrapText="true"
                               textAlignment="CENTER"
                               styleClass="brand-title"/>

                        <Label fx:id="brandTaglineLabel"
                               text="Secure Digital Examination Platform"
                               wrapText="true"
                               textAlignment="CENTER"
                               styleClass="brand-subtitle"/>
                    </VBox>

                    <Label text="Maintain academic integrity through secure and monitored assessments."
                           wrapText="true"
                           textAlignment="CENTER"
                           styleClass="brand-description"/>
                </VBox>
            </StackPane>

            <!-- RIGHT WIZARD CARD -->
            <StackPane prefWidth="760"
                       alignment="CENTER"
                       styleClass="lobby-card-side">

                <BorderPane maxWidth="720"
                            minWidth="640"
                            prefWidth="700"
                            styleClass="lobby-wizard-card">

                    <top>
                        <VBox spacing="14" styleClass="lobby-card-header">
                            <HBox alignment="CENTER_LEFT" spacing="12" >
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Exam Lobby" styleClass="lobby-eyebrow"/>
                                    <Label fx:id="lobbyExamTitleLabel"
                                           text="Exam Title"
                                           wrapText="true"
                                           styleClass="lobby-title"/>
                                </VBox>

                                <Label fx:id="lobbyStepLabel"
                                       text="Step 1 of 2"
                                       styleClass="lobby-step-pill"/>
                            </HBox>

                            <Label fx:id="lobbyExamSubtitleLabel"
                                   text="Read the rules, accept the agreement, then complete the system checks."
                                   wrapText="true"
                                   styleClass="lobby-subtitle"/>

                            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="lobby-meta-row">
                                <VBox spacing="3" styleClass="lobby-meta-item" HBox.hgrow="ALWAYS">
                                    <Label text="Duration" styleClass="lobby-meta-label"/>
                                    <Label fx:id="lobbyDurationLabel" text="--" styleClass="lobby-meta-value"/>
                                </VBox>

                                <VBox spacing="3" styleClass="lobby-meta-item" HBox.hgrow="ALWAYS">
                                    <Label text="Questions" styleClass="lobby-meta-label"/>
                                    <Label fx:id="lobbyQuestionCountLabel" text="Loads when exam starts" styleClass="lobby-meta-value"/>
                                </VBox>

                                <VBox spacing="3" styleClass="lobby-meta-item" HBox.hgrow="ALWAYS">
                                    <Label text="Status" styleClass="lobby-meta-label"/>
                                    <Label text="Not Started" styleClass="lobby-meta-value"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </top>

                    <center>
                        <StackPane styleClass="lobby-step-wrapper">

                            <!-- STEP 1 -->
                            <VBox fx:id="lobbyAgreementStep"
                                  spacing="16"
                                  styleClass="lobby-step-content">

                                <VBox spacing="5">
                                    <Label text="Exam Rules and Privacy Notice"
                                           styleClass="lobby-section-title"/>

                                    <Label text="Please read the following before proceeding to the examination setup."
                                           wrapText="true"
                                           styleClass="lobby-section-subtitle"/>
                                </VBox>

                                <VBox spacing="12"
                                      styleClass="privacy-consent-card">

                                    <Label text="By continuing, you acknowledge and agree that:"
                                           styleClass="section-title"/>

                                    <Label text="• You must remain visible within the camera view throughout the examination."
                                           wrapText="true"
                                           styleClass="lobby-rule-text"/>

                                    <Label text="• Leaving the camera view, switching applications, exiting fullscreen, or performing restricted actions may be recorded as exam violations."
                                           wrapText="true"
                                           styleClass="lobby-rule-text"/>

                                    <Label text="• Exam activity and proctoring events may be monitored for academic integrity and faculty review purposes."
                                           wrapText="true"
                                           styleClass="lobby-rule-text"/>

                                    <Label text="• Violation records are subject to faculty or authorized school personnel review before any academic decision is made."
                                           wrapText="true"
                                           styleClass="lobby-rule-text"/>

                                    <Label text="• In compliance with the Philippine Data Privacy Act of 2012 (Republic Act No. 10173), personal and examination-related data collected by ExamGuard will be processed only for legitimate academic, security, and examination purposes."
                                           wrapText="true"
                                           styleClass="lobby-rule-text"/>

                                </VBox>

                                <CheckBox fx:id="agreementCheckBox"
                                          text="I have read and understood the exam rules, privacy notice, and proctoring conditions."
                                          wrapText="true"
                                          styleClass="lobby-agreement-check"/>

                            </VBox>

                            <!-- STEP 2 -->
                            <VBox fx:id="lobbySystemCheckStep"
                                  spacing="12"
                                  visible="false"
                                  managed="false"
                                  styleClass="lobby-step-content">

                                <VBox spacing="4">
                                    <Label text="Camera Verification"
                                           styleClass="lobby-section-title"/>

                                    <Label text="Keep your face centered and fully visible in the camera before running verification."
                                           wrapText="true"
                                           styleClass="lobby-check-description"/>
                                </VBox>

                                <HBox spacing="14" alignment="TOP_CENTER">

                                    <StackPane fx:id="lobbyCameraPreviewPane"
                                               HBox.hgrow="ALWAYS"
                                               prefHeight="220"
                                               minHeight="220"
                                               maxHeight="220"
                                               styleClass="lobby-camera-preview">

                                        <ImageView fx:id="lobbyCameraPreviewImageView"
                                                   preserveRatio="true"
                                                   fitHeight="210"
                                                   smooth="true"/>

                                        <Label fx:id="lobbyCameraPreviewPlaceholder"
                                               text="Camera preview will appear here"
                                               styleClass="lobby-camera-placeholder"/>
                                    </StackPane>

                                    <VBox fx:id="phoneCameraPairingBox"
                                          spacing="8"
                                          alignment="CENTER"
                                          visible="false"
                                          managed="false"
                                          styleClass="phone-camera-qr-side">

                                        <Label text="Scan to pair phone"
                                               styleClass="phone-camera-title"/>

                                        <ImageView fx:id="phoneCameraQrImageView"
                                                   fitWidth="130"
                                                   fitHeight="130"
                                                   preserveRatio="true"
                                                   smooth="true"/>

                                        <Label fx:id="phoneCameraStatusLabel"
                                               text="Waiting"
                                               alignment="CENTER"
                                               styleClass="lobby-status-warning"/>
                                    </VBox>
                                </HBox>

                                <HBox alignment="CENTER_RIGHT">
                                    <Button fx:id="pairPhoneCameraButton"
                                            text="Use phone camera instead"
                                            onAction="#handlePairPhoneCamera"
                                            styleClass="text-link-button"/>
                                </HBox>

                                <HBox spacing="12"
                                      alignment="CENTER"
                                      fillHeight="true"
                                      styleClass="lobby-progress-row">

                                    <VBox spacing="8" alignment="TOP_CENTER" styleClass="lobby-progress-item" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                        <ImageView fitWidth="22" fitHeight="22" preserveRatio="true">
                                            <image>
                                                <Image url="@/icons/camera.png"/>
                                            </image>
                                        </ImageView>
                                        <Label text="Camera" styleClass="lobby-progress-title"/>
                                        <Label fx:id="cameraStatusLabel" text="Pending" alignment="CENTER" styleClass="lobby-status-pending"/>
                                        <Label fx:id="cameraDetailLabel" text="" wrapText="true" styleClass="lobby-progress-message"/>
                                    </VBox>

                                    <VBox spacing="8" alignment="TOP_CENTER" styleClass="lobby-progress-item" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                        <ImageView fitWidth="22" fitHeight="22" preserveRatio="true">
                                            <image>
                                                <Image url="@/icons/user.png"/>
                                            </image>
                                        </ImageView>
                                        <Label text="Visibility" styleClass="lobby-progress-title"/>
                                        <Label fx:id="faceStatusLabel" text="Pending" alignment="CENTER" styleClass="lobby-status-pending"/>
                                        <Label fx:id="faceDetailLabel" text="" wrapText="true" styleClass="lobby-progress-message"/>
                                    </VBox>

                                    <VBox spacing="8" alignment="TOP_CENTER" styleClass="lobby-progress-item" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                        <ImageView fitWidth="22" fitHeight="22" preserveRatio="true">
                                            <image>
                                                <Image url="@/icons/wi-fi.png"/>
                                            </image>
                                        </ImageView>
                                        <Label text="Connection" styleClass="lobby-progress-title"/>
                                        <Label fx:id="internetStatusLabel" text="Pending" alignment="CENTER" styleClass="lobby-status-pending"/>
                                        <Label fx:id="internetDetailLabel" text="" wrapText="true" styleClass="lobby-progress-message"/>
                                    </VBox>

                                    <VBox spacing="8" alignment="TOP_CENTER" styleClass="lobby-progress-item" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                        <ImageView fitWidth="22" fitHeight="22" preserveRatio="true">
                                            <image>
                                                <Image url="@/icons/system.png"/>
                                            </image>
                                        </ImageView>
                                        <Label text="System" styleClass="lobby-progress-title"/>
                                        <Label fx:id="systemStatusLabel" text="Pending" alignment="CENTER" styleClass="lobby-status-pending"/>
                                        <Label fx:id="systemDetailLabel" text="" wrapText="true" styleClass="lobby-progress-message"/>
                                    </VBox>

                                </HBox>

                                <HBox alignment="CENTER_RIGHT">
                                    <Button fx:id="runChecksButton"
                                            text="Verify"
                                            onAction="#handleRunLobbyChecks"
                                            styleClass="lobby-verify-button"/>
                                </HBox>

                            </VBox>

                        </StackPane>
                    </center>

                    <bottom>
                        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="lobby-footer-actions">
                            <Button fx:id="cancelLobbyButton"
                                    text="Cancel"
                                    onAction="#handleCancelLobby"
                                    styleClass="outline-button"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Button fx:id="backToAgreementButton"
                                    text="Back"
                                    onAction="#handleBackToAgreement"
                                    visible="false"
                                    managed="false"
                                    styleClass="outline-button"/>

                            <Button fx:id="continueToChecksButton"
                                    text="Continue"
                                    onAction="#handleContinueToSystemChecks"
                                    styleClass="primary-button"/>

                            <Button fx:id="beginExamButton"
                                    text="Begin Exam"
                                    onAction="#handleBeginExamFromLobby"
                                    visible="false"
                                    managed="false"
                                    styleClass="primary-button"/>
                        </HBox>
                    </bottom>
                </BorderPane>
            </StackPane>
        </HBox>
    </StackPane>

    <!-- ACTUAL EXAM CONTENT -->
    <BorderPane fx:id="examContent"
                visible="false"
                managed="false">

        <top>
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="exam-topbar">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="examTitleLabel" styleClass="exam-title"/>
                    <Label fx:id="examSubtitleLabel" styleClass="exam-subtitle"/>
                </VBox>

                <Label fx:id="timerLabel" styleClass="timer-label"/>

                <Button fx:id="submitButton"
                        text="Submit Exam"
                        onAction="#handleSubmitExam"
                        styleClass="submit-button"/>
            </HBox>
        </top>

        <left>
            <VBox spacing="14" styleClass="question-sidebar">
                <Label text="Questions" styleClass="sidebar-title"/>

                <FlowPane fx:id="questionNumberPane"
                          hgap="8"
                          vgap="8"
                          prefWrapLength="210"/>

                <Separator/>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox spacing="4" styleClass="progress-card">
                    <Label fx:id="answeredCountLabel" styleClass="progress-text"/>
                    <Label fx:id="markedCountLabel" styleClass="progress-subtext"/>
                </VBox>
            </VBox>
        </left>

        <center>
            <BorderPane styleClass="exam-content">

                <!-- Fixed question header -->
                <top>
                    <HBox alignment="CENTER_LEFT" styleClass="question-header-bar">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label fx:id="questionNumberLabel" styleClass="question-number-label"/>
                            <Label fx:id="questionTypeLabel" styleClass="question-type-label"/>
                        </VBox>

                        <Button fx:id="markReviewButton"
                                text="Mark for Review"
                                onAction="#handleMarkForReview"
                                styleClass="outline-button"/>
                    </HBox>
                </top>

                <!-- Scrollable question body only -->
                <center>
                    <ScrollPane fx:id="questionScrollPane"
                                fitToWidth="true"
                                hbarPolicy="NEVER"
                                vbarPolicy="AS_NEEDED"
                                pannable="true"
                                styleClass="exam-question-scroll">

                        <VBox spacing="18"
                              styleClass="question-card"
                              fillWidth="true"
                              maxWidth="Infinity">

                            <Label fx:id="questionTextLabel"
                                   wrapText="true"
                                   styleClass="question-text"/>

                            <StackPane fx:id="questionImageWrapper"
                                       visible="false"
                                       managed="false"
                                       alignment="CENTER"
                                       styleClass="question-image-wrapper">

                                <ImageView fx:id="questionImageView"
                                           fitWidth="640"
                                           fitHeight="260"
                                           preserveRatio="true"
                                           smooth="true"
                                           styleClass="question-image"/>
                            </StackPane>

                            <VBox fx:id="answerContainer"
                                  maxWidth="Infinity"
                                  fillWidth="true"
                                  spacing="12"/>
                        </VBox>
                    </ScrollPane>
                </center>

                <!-- Fixed navigation footer -->
                <bottom>
                    <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="exam-footer">
                        <Button fx:id="previousButton"
                                text="Previous"
                                onAction="#handlePrevious"
                                styleClass="outline-button"/>

                        <Button fx:id="nextButton"
                                text="Next"
                                onAction="#handleNext"
                                styleClass="primary-button"/>
                    </HBox>
                </bottom>

            </BorderPane>
        </center>

    </BorderPane>

    <!-- VIOLATION OVERLAY -->
    <StackPane fx:id="violationOverlay"
               visible="false"
               managed="false"
               mouseTransparent="true"
               alignment="CENTER"
               styleClass="violation-overlay">

        <VBox alignment="CENTER" spacing="8">
            <Label fx:id="violationTitleLabel"
                   text="Violation Detected"
                   styleClass="violation-title"/>

            <Label fx:id="violationMessageLabel"
                   text="Multiple faces detected"
                   wrapText="true"
                   styleClass="violation-message"/>
        </VBox>

    </StackPane>

</StackPane>
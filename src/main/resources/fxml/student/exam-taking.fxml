<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="examRoot"
           prefWidth="Infinity"
           prefHeight="Infinity"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.examguard.controller.student.ExamTakingController"
           stylesheets="/styles/exam-taking.css"
           styleClass="exam-root">

    <!-- EXAM LOBBY -->
    <StackPane fx:id="lobbyView"
               styleClass="lobby-shell-root">

        <HBox alignment="CENTER" fillHeight="true">

            <!-- LEFT BRANDING PANEL -->
            <StackPane HBox.hgrow="ALWAYS"
                       styleClass="lobby-brand-panel">

                <VBox alignment="CENTER"
                      spacing="18"
                      maxWidth="520"
                      styleClass="lobby-brand-content">

                    <ImageView fx:id="schoolLogoImageView"
                               fitWidth="255"
                               fitHeight="255"
                               preserveRatio="true"
                               smooth="true"
                               opacity="0.18"/>

                    <VBox alignment="CENTER" spacing="6">
                        <Label fx:id="brandSchoolNameLabel"
                               text="ExamGuard"
                               wrapText="true"
                               textAlignment="CENTER"
                               styleClass="brand-title"/>

                        <Label fx:id="brandTaglineLabel"
                               text="Secure Digital Examination Platform"
                               wrapText="true"
                               textAlignment="CENTER"
                               styleClass="brand-subtitle"/>
                    </VBox>

                    <Label text="Maintain academic integrity through secure and monitored assessments."
                           wrapText="true"
                           textAlignment="CENTER"
                           styleClass="brand-description"/>
                </VBox>
            </StackPane>

            <!-- RIGHT WIZARD CARD -->
            <StackPane prefWidth="760"
                       alignment="CENTER"
                       styleClass="lobby-card-side">

                <BorderPane maxWidth="720"
                            minWidth="640"
                            prefWidth="700"
                            styleClass="lobby-wizard-card">

                    <top>
                        <VBox spacing="14" styleClass="lobby-card-header">
                            <HBox alignment="CENTER_LEFT" spacing="12" >
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Exam Lobby" styleClass="lobby-eyebrow"/>
                                    <Label fx:id="lobbyExamTitleLabel"
                                           text="Exam Title"
                                           wrapText="true"
                                           styleClass="lobby-title"/>
                                </VBox>

                                <Label fx:id="lobbyStepLabel"
                                       text="Step 1 of 2"
                                       styleClass="lobby-step-pill"/>
                            </HBox>

                            <Label fx:id="lobbyExamSubtitleLabel"
                                   text="Read the rules, accept the agreement, then complete the system checks."
                                   wrapText="true"
                                   styleClass="lobby-subtitle"/>

                            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="lobby-meta-row">
                                <VBox spacing="3" styleClass="lobby-meta-item" HBox.hgrow="ALWAYS">
                                    <Label text="Duration" styleClass="lobby-meta-label"/>
                                    <Label fx:id="lobbyDurationLabel" text="--" styleClass="lobby-meta-value"/>
                                </VBox>

                                <VBox spacing="3" styleClass="lobby-meta-item" HBox.hgrow="ALWAYS">
                                    <Label text="Questions" styleClass="lobby-meta-label"/>
                                    <Label fx:id="lobbyQuestionCountLabel" text="Loads when exam starts" styleClass="lobby-meta-value"/>
                                </VBox>

                                <VBox spacing="3" styleClass="lobby-meta-item" HBox.hgrow="ALWAYS">
                                    <Label text="Status" styleClass="lobby-meta-label"/>
                                    <Label text="Not Started" styleClass="lobby-meta-value"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </top>

                    <center>
                        <StackPane styleClass="lobby-step-wrapper">

                            <!-- STEP 1 -->
                            <VBox fx:id="lobbyAgreementStep"
                                  spacing="14"
                                  styleClass="lobby-step-content">

                                <VBox spacing="5">
                                    <Label text="Exam Rules and Data Privacy Consent"
                                           styleClass="lobby-section-title"/>
                                    <Label text="You must accept the monitoring notice before ExamGuard runs the system check."
                                           wrapText="true"
                                           styleClass="lobby-section-subtitle"/>
                                </VBox>

                                <VBox spacing="8" styleClass="lobby-rules-list">
                                    <Label text="• Your camera may be used to verify your identity and monitor exam integrity."
                                           wrapText="true"
                                           styleClass="lobby-rule-text"/>
                                    <Label text="• Your face, screen behavior, and exam activity may be recorded as violation evidence."
                                           wrapText="true"
                                           styleClass="lobby-rule-text"/>
                                    <Label text="• Stay in fullscreen mode until you submit the exam."
                                           wrapText="true"
                                           styleClass="lobby-rule-text"/>
                                    <Label text="• Do not switch windows, minimize the app, right-click, or use restricted shortcuts."
                                           wrapText="true"
                                           styleClass="lobby-rule-text"/>
                                    <Label text="• Keep your face visible and keep restricted materials away from your desk."
                                           wrapText="true"
                                           styleClass="lobby-rule-text"/>
                                </VBox>

                                <CheckBox fx:id="agreementCheckBox"
                                          text="I have read and agree to the exam rules, monitoring, and data privacy notice."
                                          wrapText="true"
                                          styleClass="lobby-agreement-check"/>

                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Button fx:id="requestCameraPermissionButton"
                                            text="Allow Camera Access"
                                            onAction="#handleRequestCameraPermission"
                                            styleClass="outline-button"/>

                                    <Label fx:id="cameraPermissionStatusLabel"
                                           text="Camera permission not checked yet."
                                           wrapText="true"
                                           styleClass="lobby-rule-text"/>
                                </HBox>
                            </VBox>

                            <!-- STEP 2 -->
                            <VBox fx:id="lobbySystemCheckStep"
                                  spacing="12"
                                  visible="false"
                                  managed="false"
                                  styleClass="lobby-step-content">

                                <HBox alignment="CENTER_LEFT" spacing="12">

                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="System Readiness Check"
                                               styleClass="lobby-section-title"/>

                                        <Label text="ExamGuard will verify this device before the exam can begin."
                                               wrapText="true"
                                               styleClass="lobby-check-description"/>
                                    </VBox>

                                    <Button fx:id="runChecksButton"
                                            text="Run System Checks"
                                            onAction="#handleRunLobbyChecks"
                                            styleClass="primary-button"/>
                                </HBox>

                                <VBox spacing="8">
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="lobby-check-row">
                                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                                            <Label text="Camera Access" styleClass="lobby-check-title"/>
                                            <Label fx:id="cameraDetailLabel" text="" wrapText="true" styleClass="lobby-check-detail"/>
                                        </VBox>
                                        <Label fx:id="cameraStatusLabel" text="Pending" alignment="CENTER" styleClass="lobby-status-pending"/>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="lobby-check-row">
                                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                                            <Label text="Face Detection" styleClass="lobby-check-title"/>
                                            <Label fx:id="faceDetailLabel" text="" wrapText="true" styleClass="lobby-check-detail"/>

                                        </VBox>
                                        <Label fx:id="faceStatusLabel" text="Pending" alignment="CENTER" styleClass="lobby-status-pending"/>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="lobby-check-row">
                                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                                            <Label text="Desk Scan" styleClass="lobby-check-title"/>
                                            <Label fx:id="deskDetailLabel" text="" wrapText="true" styleClass="lobby-check-detail"/>

                                        </VBox>
                                        <Label fx:id="deskStatusLabel" text="Pending" alignment="CENTER" styleClass="lobby-status-pending"/>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="lobby-check-row">
                                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                                            <Label text="ExamGuard Connectivity" styleClass="lobby-check-title"/>
                                            <Label fx:id="internetDetailLabel" text="" wrapText="true" styleClass="lobby-check-detail"/>

                                        </VBox>
                                        <Label fx:id="internetStatusLabel" text="Pending" alignment="CENTER" styleClass="lobby-status-pending"/>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="lobby-check-row">
                                        <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                            <Label text="System Lockdown" styleClass="lobby-check-title"/>
                                            <Label fx:id="systemDetailLabel" text="" wrapText="true" styleClass="lobby-check-detail"/>

                                        </HBox>
                                        <Label fx:id="systemStatusLabel" text="Pending" alignment="CENTER" styleClass="lobby-status-pending"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </StackPane>
                    </center>

                    <bottom>
                        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="lobby-footer-actions">
                            <Button fx:id="cancelLobbyButton"
                                    text="Cancel"
                                    onAction="#handleCancelLobby"
                                    styleClass="outline-button"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Button fx:id="backToAgreementButton"
                                    text="Back"
                                    onAction="#handleBackToAgreement"
                                    visible="false"
                                    managed="false"
                                    styleClass="outline-button"/>

                            <Button fx:id="continueToChecksButton"
                                    text="Run System Check"
                                    onAction="#handleRunSystemCheck"
                                    styleClass="primary-button"/>

                            <Button fx:id="beginExamButton"
                                    text="Begin Exam"
                                    onAction="#handleBeginExamFromLobby"
                                    visible="false"
                                    managed="false"
                                    styleClass="primary-button"/>
                        </HBox>
                    </bottom>
                </BorderPane>
            </StackPane>
        </HBox>
    </StackPane>

    <!-- ACTUAL EXAM CONTENT -->
    <BorderPane fx:id="examContent"
                visible="false"
                managed="false">

        <top>
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="exam-topbar">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="examTitleLabel" styleClass="exam-title"/>
                    <Label fx:id="examSubtitleLabel" styleClass="exam-subtitle"/>
                </VBox>

                <Label fx:id="timerLabel" styleClass="timer-label"/>

                <Button fx:id="submitButton"
                        text="Submit Exam"
                        onAction="#handleSubmitExam"
                        styleClass="submit-button"/>
            </HBox>
        </top>

        <left>
            <VBox spacing="14" styleClass="question-sidebar">
                <Label text="Questions" styleClass="sidebar-title"/>

                <FlowPane fx:id="questionNumberPane"
                          hgap="8"
                          vgap="8"
                          prefWrapLength="210"/>

                <Separator/>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox spacing="4" styleClass="progress-card">
                    <Label fx:id="answeredCountLabel" styleClass="progress-text"/>
                    <Label fx:id="markedCountLabel" styleClass="progress-subtext"/>
                </VBox>
            </VBox>
        </left>

        <center>
            <VBox spacing="18" styleClass="exam-content">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label fx:id="questionNumberLabel" styleClass="question-number-label"/>
                        <Label fx:id="questionTypeLabel" styleClass="question-type-label"/>
                    </VBox>

                    <Button fx:id="markReviewButton"
                            text="Mark for Review"
                            onAction="#handleMarkForReview"
                            styleClass="outline-button"/>
                </HBox>

                <VBox spacing="18"
                      styleClass="question-card"
                      fillWidth="true"
                      maxWidth="Infinity"
                      VBox.vgrow="ALWAYS">

                    <Label fx:id="questionTextLabel"
                           wrapText="true"
                           styleClass="question-text"/>

                    <StackPane fx:id="questionImageWrapper"
                               visible="false"
                               managed="false"
                               alignment="CENTER"
                               styleClass="question-image-wrapper">

                        <ImageView fx:id="questionImageView"
                                   fitWidth="640"
                                   fitHeight="320"
                                   preserveRatio="true"
                                   smooth="true"
                                   styleClass="question-image"/>
                    </StackPane>

                    <VBox fx:id="answerContainer"
                          maxWidth="Infinity"
                          fillWidth="true"
                          spacing="12"
                          VBox.vgrow="ALWAYS"/>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="exam-footer">
                    <Button fx:id="previousButton"
                            text="Previous"
                            onAction="#handlePrevious"
                            styleClass="outline-button"/>

                    <Button fx:id="nextButton"
                            text="Next"
                            onAction="#handleNext"
                            styleClass="primary-button"/>
                </HBox>
            </VBox>
        </center>

    </BorderPane>

    <!-- VIOLATION OVERLAY -->
    <StackPane fx:id="violationOverlay"
               visible="false"
               managed="false"
               mouseTransparent="true"
               alignment="CENTER"
               styleClass="violation-overlay">

        <VBox alignment="CENTER" spacing="8">
            <Label fx:id="violationTitleLabel"
                   text="Violation Detected"
                   styleClass="violation-title"/>

            <Label fx:id="violationMessageLabel"
                   text="Multiple faces detected"
                   wrapText="true"
                   styleClass="violation-message"/>
        </VBox>

    </StackPane>

</StackPane>
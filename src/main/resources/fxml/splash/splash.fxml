<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.examguard.controller.SplashController"
           style="-fx-background-color: #1e1e2f;">

    <VBox alignment="CENTER" spacing="15">

        <Label text="ExamGuard"
               style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;" />

        <Label text="Secure Online Examination System"
               style="-fx-text-fill: #cccccc; -fx-font-size: 14px;" />

        <ProgressBar fx:id="progressBar"
                     prefWidth="250"
                     progress="0" />

        <Label fx:id="statusLabel"
               text="Starting..."
               style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;" />

    </VBox>

</StackPane>